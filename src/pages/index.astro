---
// =============================================================================
// DEGLOB — Homepage (fantasyglobos.com.mx)
// Decoración profesional con globos en CDMX
// =============================================================================

import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import CtaBar from '../components/CtaBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CategoryCard from '../components/CategoryCard.astro';
import FaqSection from '../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../lib/config';
import { organizationSchema, localBusinessSchema, webSiteSchema, faqSchema } from '../lib/seo';

// -- FAQ Items --
const faqItems = [
  {
    pregunta: '¿Qué tipos de decoración con globos ofrecen?',
    respuesta: 'Ofrecemos arcos orgánicos y clásicos, columnas decorativas, guirnaldas, backdrops y paneles, globos con helio, figuras personalizadas, centros de mesa y globos gigantes. Cada servicio se adapta a la temática y estilo de tu evento.',
  },
  {
    pregunta: '¿Incluyen instalación y desmontaje?',
    respuesta: 'Sí, todos nuestros paquetes incluyen instalación profesional en el lugar de tu evento. En los paquetes de producción completa también incluimos el desmontaje al finalizar el evento.',
  },
  {
    pregunta: '¿Con cuánta anticipación debo reservar?',
    respuesta: 'Recomendamos reservar con al menos 2 semanas de anticipación para garantizar disponibilidad. Para eventos grandes como bodas o XV años, lo ideal es agendar con 1 a 2 meses de anticipación.',
  },
  {
    pregunta: '¿Cubren toda la Ciudad de México?',
    respuesta: 'Sí, cubrimos toda la CDMX y Zona Metropolitana incluyendo Polanco, Santa Fe, Coyoacán, Condesa, Roma, Del Valle, Naucalpan, Tlalnepantla, Huixquilucan y Satélite. El servicio de instalación está incluido sin costo adicional.',
  },
  {
    pregunta: '¿Puedo elegir los colores y la temática?',
    respuesta: 'Por supuesto. Trabajamos con una amplia gama de colores en globos latex, chrome, pastel, confeti y foil. Nos adaptamos a la paleta de colores y temática de tu evento para crear una decoración coherente y espectacular.',
  },
  {
    pregunta: '¿Cuánto dura la decoración con globos?',
    respuesta: 'La decoración con globos de aire dura entre 3 y 5 días en condiciones normales. Los globos con helio duran entre 8 y 12 horas. Recomendamos instalar lo más cercano posible al inicio del evento para un resultado óptimo.',
  },
  {
    pregunta: '¿Qué métodos de pago aceptan?',
    respuesta: 'Aceptamos efectivo, transferencia bancaria y tarjetas de crédito/débito. Para reservar, solicitamos un anticipo del 50% y el resto se liquida antes de la instalación.',
  },
  {
    pregunta: '¿Ofrecen servicio para eventos corporativos?',
    respuesta: 'Sí, atendemos eventos corporativos como inauguraciones, lanzamientos de productos, convenciones y fiestas empresariales. Ofrecemos facturación y podemos adaptar la decoración a la imagen corporativa de tu empresa.',
  },
];

// -- Structured Data --
const structuredData = [
  organizationSchema(),
  localBusinessSchema(),
  webSiteSchema(),
  faqSchema(faqItems),
];
---

<Base
  title="DEGLOB — Decoración Profesional con Globos para Eventos en CDMX"
  description="Decoración profesional con globos para bodas, XV años, baby showers, cumpleaños y eventos corporativos en CDMX. Arcos, columnas, guirnaldas, figuras y más. Instalación incluida."
  structuredData={structuredData}
>


  <!-- ====== HERO ====== -->
  <Hero
    badge="Decoración con Globos CDMX"
    title="Decoración Profesional con Globos para tu Evento"
    description="Transformamos tus celebraciones con decoraciones de globos espectaculares. Arcos, columnas, guirnaldas, figuras personalizadas y más para bodas, XV años, baby showers y eventos corporativos en la Ciudad de México."
    primaryCta={{ text: 'Cotizar Gratis', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver Servicios', href: '/servicios/' }}

  >
    <Fragment slot="hero-seo">
      <p>
        En <strong>DEGLOB</strong> somos especialistas en <strong>decoración con globos para eventos en CDMX</strong>.
        Diseñamos e instalamos arcos orgánicos, columnas decorativas, guirnaldas, backdrops, figuras personalizadas
        y arreglos con helio que transforman cualquier espacio en una experiencia inolvidable para tus invitados.
      </p>
      <p>
        Ya sea una <strong>boda elegante</strong>, unos <strong>XV años</strong>, un <strong>baby shower</strong>,
        un <strong>cumpleaños temático</strong> o un <strong>evento corporativo</strong>, nuestro equipo de decoradores
        profesionales se encarga de todo: desde el diseño creativo hasta la instalación en el lugar de tu evento.
        Cubrimos toda la <strong>Ciudad de México y Zona Metropolitana</strong> con materiales premium y atención personalizada.
      </p>
    </Fragment>
  </Hero>

  <!-- ====== CTA BAR ====== -->
  <CtaBar
    items={[
      { label: 'Arcos', icon: 'arcos', href: '/servicios/arcos-de-globos/' },
      { label: 'Guirnaldas', icon: 'guirnaldas', href: '/servicios/guirnaldas-de-globos/' },
      { label: 'Helio', icon: 'helio', href: '/servicios/globos-helio/' },
      { label: 'Cotizar', icon: 'cotizar', href: WHATSAPP_URL_MSG },
    ]}
  />

  <!-- ====== SERVICIOS ====== -->
  <section class="section" aria-labelledby="servicios-title">
    <div class="container">
      <SectionHeader
        badge="Lo que hacemos"
        title="Nuestros Servicios"
        subtitle="Ofrecemos una amplia gama de decoraciones con globos para todo tipo de eventos. Cada servicio incluye diseño personalizado e instalación profesional en CDMX."
        id="servicios-title"
      />
      <div class="grid-4">
        {SERVICIOS.map((s) => (
          <CategoryCard
            title={s.nombre}
            subtitle={s.descripcion}
            href={`/servicios/${s.slug}/`}
            image={s.imagen}
            subcategories={s.paquetes.map((p) => ({
              name: p.nombre,
              href: `/servicios/${s.slug}/${p.slug}/`,
            }))}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ====== EVENTOS ====== -->
  <section class="section section--alt" aria-labelledby="eventos-title">
    <div class="container">
      <SectionHeader
        badge="Tipos de evento"
        title="Decoramos Todo Tipo de Eventos"
        subtitle="Nos especializamos en crear la ambientación perfecta con globos para cada tipo de celebración. Instalación profesional incluida en toda la CDMX."
        id="eventos-title"
      />
      <div class="grid-4">
        {[
          { nombre: 'Bodas', slug: 'bodas', imagen: '/img/arcos-de-globos/arco-globos-boda-elegante-verde-durazno-follaje.webp', descripcion: 'Arcos románticos, backdrops y centros de mesa para el día más especial.' },
          { nombre: 'XV Años', slug: 'xv-anos', imagen: '/img/arcos-de-globos/arco-globos-quince-anos-azul-plateado-pista.webp', descripcion: 'Decoración espectacular para la fiesta de quinceañera soñada.' },
          { nombre: 'Baby Shower', slug: 'baby-shower', imagen: '/img/arcos-de-globos/arco-globos-baby-shower-rosa-durazno-its-a-girl.webp', descripcion: 'Arreglos tiernos y elegantes para recibir a tu bebé.' },
          { nombre: 'Cumpleaños Infantil', slug: 'cumpleanos-infantil', imagen: '/img/globos-para-cumpleanos/arco-globos-unicornio-magico-fiesta-princesa.webp', descripcion: 'Figuras de personajes, arcos y temáticas mágicas para niños.' },
          { nombre: 'Cumpleaños Adulto', slug: 'cumpleanos-adulto', imagen: '/img/globos-centro-de-mesas/centro-mesa-globos-numero-dorado-cumpleanos-adulto.webp', descripcion: 'Decoraciones sofisticadas en chrome y dorado para adultos.' },
          { nombre: 'Corporativos', slug: 'corporativos', imagen: '/img/columnas-decorativas/columnas-globos-apertura-azul-blanco-dorado-empresa.webp', descripcion: 'Decoración profesional para inauguraciones y eventos de empresa.' },
          { nombre: 'Graduaciones', slug: 'graduaciones', imagen: '/img/globos-helio/bouquet-globos-graduacion-negro-dorado-estrellas.webp', descripcion: 'Celebra tu logro académico con globos elegantes y temáticos.' },
          { nombre: 'Gender Reveal', slug: 'gender-reveal', imagen: '/img/globos-gigantes/globo-gigante-confeti-rosa-cumpleanos-infantil-nina.webp', descripcion: 'Globos gigantes y decoración para revelar el sexo del bebé.' },
        ].map((e) => (
          <a href={`/eventos/${e.slug}/`} class="event-card">
            <div class="event-card__img-wrap">
              <img src={e.imagen} alt={`Decoración con globos para ${e.nombre} en CDMX`} loading="lazy" decoding="async" width="640" height="360" />
            </div>
            <div class="event-card__body">
              <h3 class="event-card__title">{e.nombre}</h3>
              <p class="event-card__desc">{e.descripcion}</p>
              <span class="event-card__btn">Ver más</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <FaqSection items={faqItems} />

  <!-- ====== TESTIMONIOS ====== -->
  <section class="section section--alt" aria-labelledby="testimonios-title">
    <div class="container">
      <SectionHeader
        badge="Clientes felices"
        title="Lo Que Dicen Nuestros Clientes"
        subtitle="Más de 500 eventos decorados con globos en CDMX. Estas son las experiencias de quienes confiaron en DEGLOB para sus celebraciones."
        id="testimonios-title"
      />
      <div class="testimonials-grid">

        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <p class="testimonial-card__quote">
            "El arco de globos para nuestra boda quedó espectacular. Superó todas nuestras expectativas. El equipo de DEGLOB fue muy profesional y puntual con la instalación."
          </p>
          <div class="testimonial-card__author">
            <span class="testimonial-card__name">Carolina M.</span>
            <span class="testimonial-card__event">Boda en Polanco</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <p class="testimonial-card__quote">
            "Contratamos la decoración completa para los XV años de mi hija. Las columnas, el backdrop y los centros de mesa quedaron increíbles. Todos los invitados quedaron encantados."
          </p>
          <div class="testimonial-card__author">
            <span class="testimonial-card__name">Laura G.</span>
            <span class="testimonial-card__event">XV Años en Coyoacán</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <p class="testimonial-card__quote">
            "La guirnalda orgánica para el baby shower de mi esposa fue hermosa. Los colores combinaron perfecto con la temática. Sin duda volveremos a contratarlos."
          </p>
          <div class="testimonial-card__author">
            <span class="testimonial-card__name">Roberto S.</span>
            <span class="testimonial-card__event">Baby Shower en Nápoles</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <p class="testimonial-card__quote">
            "Excelente servicio para nuestro evento corporativo. Las figuras personalizadas con el logo de la empresa fueron un éxito total. Muy recomendados."
          </p>
          <div class="testimonial-card__author">
            <span class="testimonial-card__name">Andrea P.</span>
            <span class="testimonial-card__event">Evento Corporativo en Santa Fe</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <p class="testimonial-card__quote">
            "Los globos gigantes para el gender reveal fueron perfectos. El momento de la revelación fue mágico gracias a DEGLOB. El confeti azul salió espectacular."
          </p>
          <div class="testimonial-card__author">
            <span class="testimonial-card__name">Daniela y Marcos</span>
            <span class="testimonial-card__event">Gender Reveal en Condesa</span>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="testimonial-card__stars">★★★★★</div>
          <p class="testimonial-card__quote">
            "El techo flotante con globos de helio para el cumpleaños de mi hijo fue increíble. Los niños no paraban de ver hacia arriba. Servicio puntual y muy amables."
          </p>
          <div class="testimonial-card__author">
            <span class="testimonial-card__name">Patricia V.</span>
            <span class="testimonial-card__event">Cumpleaños en Del Valle</span>
          </div>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  .event-card { background: var(--color-white); border-radius: var(--border-radius-lg); overflow: hidden; display: flex; flex-direction: column; box-shadow: var(--shadow-sm); text-decoration: none; transition: box-shadow 0.2s; }
  .event-card:hover { box-shadow: var(--shadow-md); }
  .event-card__img-wrap { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--color-bg); }
  .event-card__img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .event-card__body { padding: var(--spacing-lg); display: flex; flex-direction: column; gap: var(--spacing-xs); flex: 1; }
  .event-card__title { font-size: var(--font-size-lg); font-weight: 700; color: var(--color-text); margin: 0; }
  .event-card__desc { font-size: var(--font-size-sm); color: var(--color-text-light); line-height: 1.6; margin: 0; flex: 1; }
  .event-card__btn { display: inline-block; margin-top: auto; padding-top: 0.75rem; font-size: var(--font-size-sm); font-weight: 600; color: var(--color-primary); }
</style>
