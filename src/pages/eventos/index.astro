---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import FaqSection from '../../components/FaqSection.astro';
import { WHATSAPP_URL_MSG, SITE_URL } from '../../lib/config';
import { faqSchema } from '../../lib/seo';

const eventos = [
  { nombre: 'Bodas', slug: 'bodas', imagen: '/img/arcos-de-globos/arco-globos-boda-elegante-verde-durazno-follaje.webp', descripcion: 'Arcos románticos, backdrops y centros de mesa para el día más especial.' },
  { nombre: 'XV Años', slug: 'xv-anos', imagen: '/img/arcos-de-globos/arco-globos-quince-anos-azul-plateado-pista.webp', descripcion: 'Decoración espectacular para la fiesta de quinceañera soñada.' },
  { nombre: 'Baby Shower', slug: 'baby-shower', imagen: '/img/arcos-de-globos/arco-globos-baby-shower-rosa-durazno-its-a-girl.webp', descripcion: 'Arreglos tiernos y elegantes para recibir a tu bebé.' },
  { nombre: 'Cumpleaños Infantil', slug: 'cumpleanos-infantil', imagen: '/img/globos-para-cumpleanos/arco-globos-unicornio-magico-fiesta-princesa.webp', descripcion: 'Figuras de personajes, arcos y temáticas mágicas para niños.' },
  { nombre: 'Cumpleaños Adulto', slug: 'cumpleanos-adulto', imagen: '/img/globos-centro-de-mesas/centro-mesa-globos-numero-dorado-cumpleanos-adulto.webp', descripcion: 'Decoraciones sofisticadas en chrome y dorado para adultos.' },
  { nombre: 'Corporativos', slug: 'corporativos', imagen: '/img/columnas-decorativas/columnas-globos-apertura-azul-blanco-dorado-empresa.webp', descripcion: 'Decoración profesional para inauguraciones y eventos de empresa.' },
  { nombre: 'Graduaciones', slug: 'graduaciones', imagen: '/img/globos-helio/bouquet-globos-graduacion-negro-dorado-estrellas.webp', descripcion: 'Celebra tu logro académico con globos elegantes y temáticos.' },
  { nombre: 'Gender Reveal', slug: 'gender-reveal', imagen: '/img/globos-gigantes/globo-gigante-confeti-rosa-cumpleanos-infantil-nina.webp', descripcion: 'Globos gigantes y decoración para revelar el sexo del bebé.' },
];

const faqItems = [
  { pregunta: '¿Para qué tipos de eventos ofrecen decoración con globos?', respuesta: 'Ofrecemos decoración profesional con globos para bodas, XV años, baby showers, cumpleaños infantiles y de adultos, eventos corporativos, graduaciones, gender reveals y cualquier tipo de celebración que requiera decoración en CDMX.' },
  { pregunta: '¿Cubren toda la Ciudad de México?', respuesta: 'Sí, cubrimos toda la CDMX y zona metropolitana incluyendo Polanco, Santa Fe, Coyoacán, Condesa, Roma, Del Valle, Naucalpan, Tlalnepantla, Huixquilucan, Satélite y más. La instalación está incluida en todos nuestros paquetes.' },
  { pregunta: '¿Cómo cotizo la decoración para mi evento?', respuesta: 'Envíanos un mensaje por WhatsApp con el tipo de evento, fecha, número de invitados y venue. Te respondemos con una cotización personalizada en menos de 2 horas.' },
  { pregunta: '¿Incluyen instalación en todos los eventos?', respuesta: 'Sí, todos nuestros paquetes incluyen transporte, instalación profesional y el material necesario. En paquetes de producción completa también incluimos desmontaje.' },
  { pregunta: '¿Con cuánta anticipación debo reservar?', respuesta: 'Recomendamos reservar con 2 semanas de anticipación mínimo. Para eventos grandes como bodas y XV años, lo ideal es agendar con 1 a 2 meses de anticipación.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Decoración con Globos para Eventos en CDMX',
    description: 'Servicio profesional de decoración con globos para todo tipo de eventos: bodas, XV años, baby showers, cumpleaños, corporativos y más en CDMX.',
    provider: { '@type': 'Organization', name: 'DEGLOB', url: SITE_URL },
    areaServed: 'Ciudad de México',
  },
  faqSchema(faqItems),
];
---

<Base
  title="Eventos — Decoración con Globos para Todo Tipo de Evento | DEGLOB"
  description="Decoración profesional con globos para bodas, XV años, baby showers, cumpleaños, corporativos, graduaciones y gender reveals en CDMX. Instalación incluida."
  structuredData={structuredData}
>
  <Hero
    badge="Eventos"
    title="Decoración con Globos para Todo Tipo de Evento"
    description="En DEGLOB decoramos bodas, XV años, baby showers, cumpleaños, eventos corporativos, graduaciones y gender reveals con globos premium. Instalación profesional incluida en toda la CDMX."
    primaryCta={{ text: 'Cotizar Ahora', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver Eventos', href: '#eventos' }}
  >
    <Fragment slot="hero-seo">
      <p>Cada tipo de evento tiene necesidades decorativas diferentes, y en <strong>DEGLOB</strong> nos especializamos en crear la ambientación perfecta con globos para cada ocasión. Desde la elegancia de una boda hasta la diversión de una fiesta infantil, adaptamos nuestros diseños y materiales para lograr el resultado ideal.</p>
      <p>Nuestro equipo de decoradores profesionales cubre toda la <strong>Ciudad de México y zona metropolitana</strong>, ofreciendo instalación incluida, asesoría de diseño y la garantía de materiales premium que duran todo tu evento.</p>
    </Fragment>
  </Hero>

  <section class="section" id="eventos">
    <div class="container">
      <SectionHeader
        badge="Celebraciones"
        title="Tipo de Evento"
        subtitle="Selecciona tu tipo de evento para ver los servicios recomendados, galería de inspiración y preguntas frecuentes específicas."
      />
      <div class="grid-4">
        {eventos.map((e) => (
          <a href={`/eventos/${e.slug}/`} class="event-card">
            <div class="event-card__img-wrap">
              <img src={e.imagen} alt={`Decoración con globos para ${e.nombre} en CDMX`} loading="lazy" decoding="async" width="640" height="360" />
            </div>
            <div class="event-card__body">
              <h3 class="event-card__title">{e.nombre}</h3>
              <p class="event-card__desc">{e.descripcion}</p>
              <span class="event-card__btn">Ver más</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿No encuentras tu tipo de evento?</h2>
      <p class="cta-dark__text">Decoramos cualquier celebración con globos. Cuéntanos tu idea y te cotizamos sin compromiso.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .grid-4 { display: grid; grid-template-columns: repeat(1, 1fr); gap: 1.5rem; }
  @media (min-width: 640px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .grid-4 { grid-template-columns: repeat(4, 1fr); } }
  .event-card { background: var(--color-white); border-radius: var(--border-radius-lg); overflow: hidden; display: flex; flex-direction: column; box-shadow: var(--shadow-sm); text-decoration: none; transition: box-shadow 0.2s; }
  .event-card:hover { box-shadow: var(--shadow-md); }
  .event-card__img-wrap { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--color-bg); }
  .event-card__img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .event-card__body { padding: var(--spacing-lg); display: flex; flex-direction: column; gap: var(--spacing-xs); flex: 1; }
  .event-card__title { font-size: var(--font-size-lg); font-weight: 700; color: var(--color-text); margin: 0; }
  .event-card__desc { font-size: var(--font-size-sm); color: var(--color-text-light); line-height: 1.6; margin: 0; flex: 1; }
  .event-card__btn { display: inline-block; margin-top: auto; padding-top: 0.75rem; font-size: var(--font-size-sm); font-weight: 600; color: var(--color-primary); }
</style>
