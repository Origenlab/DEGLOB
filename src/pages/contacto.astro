---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CtaBar from '../components/CtaBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { WHATSAPP_URL_MSG, PHONE_DISPLAY, PHONE_URL, EMAIL, EMAIL_URL, BUSINESS_HOURS, LOCATION, SOCIAL_MEDIA } from '../lib/config';
import { organizationSchema, breadcrumbSchema } from '../lib/seo';
---

<Base
  title="Contacto — DEGLOB | Decoración con Globos CDMX"
  description="Contacta a DEGLOB para cotizar decoración con globos en CDMX. WhatsApp, teléfono, correo y ubicación. Respuesta en menos de 2 horas. Cotización sin compromiso."
  structuredData={[organizationSchema()]}
>

  <Breadcrumb items={[{ name: 'Contacto', href: '/contacto/' }]} />

  <Hero
    badge="Contacto"
    title="Cotiza tu Decoración con Globos"
    description="Platícanos tu idea y te ayudamos a hacerla realidad. Recibe una cotización personalizada sin compromiso para tu evento en CDMX. Respondemos en menos de 2 horas."
    primaryCta={{ text: 'WhatsApp', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: PHONE_DISPLAY, href: PHONE_URL }}
  />

  <CtaBar items={[
    { label: 'Servicios', href: '/servicios/', icon: 'servicios' },
    { label: 'Cotizar', href: WHATSAPP_URL_MSG, icon: 'cotizar' },
    { label: 'Blog', href: '/blog/' },
    { label: 'Nosotros', href: '/nosotros/' },
  ]} />

  <!-- Información de contacto -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2 class="contact-info__title">Información de Contacto</h2>

          <div class="contact-info__item">
            <span class="contact-info__label">Teléfono</span>
            <a href={PHONE_URL} class="contact-info__value">{PHONE_DISPLAY}</a>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__label">WhatsApp</span>
            <a href={WHATSAPP_URL_MSG} class="contact-info__value" target="_blank" rel="noopener">{PHONE_DISPLAY}</a>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__label">Correo Electrónico</span>
            <a href={EMAIL_URL} class="contact-info__value">{EMAIL}</a>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__label">Dirección</span>
            <span class="contact-info__value">{LOCATION.street}, {LOCATION.colony}, {LOCATION.municipality}, {LOCATION.region} {LOCATION.postalCode}</span>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__label">Horario de Atención</span>
            <span class="contact-info__value">{BUSINESS_HOURS.weekdays}</span>
            <span class="contact-info__value">{BUSINESS_HOURS.saturday}</span>
          </div>
        </div>

        <div class="contact-info">
          <h2 class="contact-info__title">Síguenos en Redes</h2>

          <div class="contact-info__item">
            <span class="contact-info__label">Facebook</span>
            <a href={SOCIAL_MEDIA.facebook} class="contact-info__value" target="_blank" rel="noopener noreferrer">@deglob</a>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__label">Instagram</span>
            <a href={SOCIAL_MEDIA.instagram} class="contact-info__value" target="_blank" rel="noopener noreferrer">@deglob</a>
          </div>

          <div class="contact-info__item">
            <span class="contact-info__label">TikTok</span>
            <a href={SOCIAL_MEDIA.tiktok} class="contact-info__value" target="_blank" rel="noopener noreferrer">@deglob</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mapa -->
  <section class="section section--bg">
    <div class="container">
      <SectionHeader
        badge="Ubicación"
        title="Encuéntranos en CDMX"
        subtitle="Estamos ubicados en Polanco, Miguel Hidalgo. Atendemos eventos en toda la Ciudad de México y zona metropolitana."
      />
      <div class="map-placeholder">
        <p class="map-placeholder__text">{LOCATION.street}, {LOCATION.colony}, {LOCATION.municipality}, {LOCATION.region} C.P. {LOCATION.postalCode}</p>
        <a href={`https://maps.google.com/?q=${encodeURIComponent(LOCATION.street + ', ' + LOCATION.colony + ', ' + LOCATION.region)}`} class="btn btn--accent" target="_blank" rel="noopener noreferrer">Ver en Google Maps</a>
      </div>
    </div>
  </section>

  <!-- CTA Dark -->
  <section class="cta-dark">
    <div class="container" style="text-align:center">
      <h2 class="cta-dark__title">¿Listo para tu Evento?</h2>
      <p class="cta-dark__text">Cotiza sin compromiso y recibe una propuesta personalizada para tu decoración con globos. Respondemos en menos de 2 horas.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2rem">
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
        <a href={PHONE_URL} class="btn btn--outline">Llamar Ahora</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .map-placeholder {
    background: var(--color-white);
    border: 2px dashed var(--color-border);
    border-radius: var(--border-radius-lg, 12px);
    padding: var(--spacing-2xl);
    text-align: center;
  }

  .map-placeholder__text {
    font-size: var(--font-size-lg);
    color: var(--color-text-light);
    margin-bottom: var(--spacing-md);
    line-height: 1.6;
  }
</style>
