---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBar from '../../components/CtaBar.astro';
import { WHATSAPP_URL_MSG } from '../../lib/config';

const articles = [
  {
    slug: 'decoracion-globos-bodas-cdmx',
    title: 'Decoración con Globos para Bodas en CDMX: Ideas y Tendencias',
    excerpt: 'Descubre las mejores ideas de decoración con globos para bodas en Ciudad de México. Desde arcos románticos hasta centros de mesa elegantes que transformarán tu celebración.',
    category: 'Bodas',
    date: '2025-11-15',
  },
  {
    slug: 'arcos-globos-tendencias',
    title: 'Tendencias en Arcos de Globos para Eventos',
    excerpt: 'Conoce las últimas tendencias en arcos de globos: orgánicos, asimétricos, con flores y más. Inspírate para tu próximo evento con los estilos más solicitados.',
    category: 'Tendencias',
    date: '2025-10-28',
  },
  {
    slug: 'globos-baby-shower-ideas',
    title: 'Ideas de Globos para Baby Shower: Guía Completa',
    excerpt: 'Las mejores ideas de decoración con globos para baby shower. Paletas de colores, arreglos temáticos y tips para crear un ambiente mágico para la llegada del bebé.',
    category: 'Baby Shower',
    date: '2025-10-10',
  },
  {
    slug: 'globos-helio-vs-aire',
    title: 'Globos de Helio vs Aire: Guía Completa para tu Evento',
    excerpt: 'Aprende las diferencias entre globos de helio y de aire, cuándo usar cada tipo, duración, costos y cuál es la mejor opción según el tipo de evento que planeas.',
    category: 'Guías',
    date: '2025-09-22',
  },
  {
    slug: 'decoracion-xv-anos-globos',
    title: 'Decoración con Globos para XV Años: Ideas Espectaculares',
    excerpt: 'Transforma la fiesta de XV años con decoración profesional de globos. Ideas de arcos, columnas, backdrops y centros de mesa que harán inolvidable la celebración.',
    category: 'XV Años',
    date: '2025-09-05',
  },
  {
    slug: 'guirnaldas-organicas-globos',
    title: 'Guirnaldas Orgánicas de Globos: Todo lo que Necesitas Saber',
    excerpt: 'Las guirnaldas orgánicas son la tendencia más solicitada en decoración con globos. Aprende sobre estilos, combinaciones de colores y cómo usarlas en tu evento.',
    category: 'Tendencias',
    date: '2025-08-18',
  },
  {
    slug: 'gender-reveal-globos-gigantes',
    title: 'Gender Reveal con Globos Gigantes: Cómo Hacerlo Perfecto',
    excerpt: 'Organiza un gender reveal inolvidable con globos gigantes. Te explicamos opciones, colores, logística y cómo crear el momento sorpresa perfecto.',
    category: 'Gender Reveal',
    date: '2025-08-01',
  },
  {
    slug: 'centros-mesa-globos-elegantes',
    title: 'Centros de Mesa con Globos Elegantes para Eventos',
    excerpt: 'Crea centros de mesa sofisticados con globos para bodas, XV años y eventos corporativos. Ideas de diseño, combinaciones y tips para un resultado profesional.',
    category: 'Decoración',
    date: '2025-07-14',
  },
  {
    slug: 'globos-eventos-corporativos',
    title: 'Globos para Eventos Corporativos: Profesionalismo y Estilo',
    excerpt: 'La decoración con globos en eventos corporativos aporta dinamismo y personalización de marca. Descubre cómo integrarlos en lanzamientos, convenciones y fiestas empresariales.',
    category: 'Corporativos',
    date: '2025-06-27',
  },
  {
    slug: 'como-elegir-decoracion-globos',
    title: 'Cómo Elegir la Mejor Decoración con Globos para tu Evento',
    excerpt: 'Guía paso a paso para elegir la decoración con globos ideal. Considera el tipo de evento, presupuesto, espacio y estilo para tomar la mejor decisión.',
    category: 'Guías',
    date: '2025-06-10',
  },
];

const structuredData = [{
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog de Decoración con Globos — DEGLOB',
  description: 'Tips, tendencias e ideas de decoración con globos para todo tipo de eventos en CDMX.',
  url: 'https://fantasyglobos.com.mx/blog/',
  publisher: { '@type': 'Organization', name: 'DEGLOB', url: 'https://fantasyglobos.com.mx' },
}];
---

<Base
  title="Blog de Decoración con Globos — DEGLOB"
  description="Tips, tendencias e ideas de decoración con globos para bodas, XV años, baby shower y eventos corporativos en CDMX. Inspírate con nuestro blog."
  structuredData={structuredData}
>
  <Breadcrumb items={[{ name: 'Blog', href: '/blog/' }]} />

  <Hero
    badge="Blog"
    title="Blog de Decoración con Globos"
    description="Tips, tendencias e inspiración para transformar tus eventos con globos. Descubre ideas creativas, guías prácticas y las últimas novedades en decoración con globos en CDMX."
    primaryCta={{ text: 'Cotizar Decoración', href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver Servicios', href: '/servicios/' }}
  />

  <CtaBar
    headline="Explora por tipo de evento"
    items={[
      { label: 'Bodas', href: '#', icon: 'globos' },
      { label: 'XV Años', href: '#', icon: 'servicios' },
      { label: 'Baby Shower', href: '#', icon: 'globos' },
      { label: 'Corporativos', href: '#', icon: 'figuras' },
    ]}
  />

  <section class="blog-section">
    <div class="container">
      <div class="blog-grid">
        {articles.map((article) => (
          <article class="blog-card">
            <div class="blog-card__body">
              <span class="blog-card__category">{article.category}</span>
              <h2 class="blog-card__title">
                <a href={`/blog/${article.slug}/`}>{article.title}</a>
              </h2>
              <p class="blog-card__excerpt">{article.excerpt}</p>
              <div class="blog-card__footer">
                <time class="blog-card__date" datetime={article.date}>
                  {new Date(article.date).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <a href={`/blog/${article.slug}/`} class="blog-card__link">Leer artículo &rarr;</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .blog-section {
    padding: var(--spacing-2xl) 0;
    background: var(--color-white);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg, 12px);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .blog-card:hover {
    box-shadow: 0 8px 24px rgba(139, 48, 238, 0.1);
    transform: translateY(-2px);
  }

  .blog-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .blog-card__category {
    display: inline-block;
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-primary, #8B30EE);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    background: rgba(139, 48, 238, 0.08);
    border-radius: 4px;
  }

  .blog-card__title {
    font-size: var(--font-size-lg, 1.125rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .blog-card__title a {
    color: var(--color-text, #1a1a2e);
    text-decoration: none;
  }

  .blog-card__title a:hover {
    color: var(--color-primary, #8B30EE);
  }

  .blog-card__excerpt {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .blog-card__date {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-text-light);
  }

  .blog-card__link {
    font-size: var(--font-size-xs, 0.75rem);
    font-weight: 600;
    color: var(--color-primary, #8B30EE);
    text-decoration: none;
  }

  .blog-card__link:hover {
    text-decoration: underline;
  }
</style>
