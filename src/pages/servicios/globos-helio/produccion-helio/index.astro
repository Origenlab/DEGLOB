---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'globos-helio')!;
const paquete = servicio.paquetes.find(p => p.slug === 'produccion-helio')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'produccion-helio');

const faqItems = [
  { pregunta: '¿Qué incluye la producción completa de globos con helio?', respuesta: 'Incluye más de 100 globos con helio distribuidos en techo flotante, bouquets decorativos, centros de mesa y arreglos especiales. Además: diseño personalizado, instalación profesional, desmontaje y coordinación con tu venue.' },
  { pregunta: '¿Cuántos globos se necesitan para cubrir un techo completo?', respuesta: 'Depende del tamaño del salón. Para un salón estándar de 100-150 personas se necesitan entre 100 y 200 globos de helio. En la asesoría de diseño calculamos la cantidad exacta según las dimensiones de tu espacio.' },
  { pregunta: '¿Pueden hacer un release o suelta de globos?', respuesta: 'Sí, podemos organizar una suelta de globos de helio como momento especial del evento. Utilizamos globos biodegradables y coordinamos el momento exacto con tu DJ o maestro de ceremonias.' },
  { pregunta: '¿El helio es seguro para eventos en espacios cerrados?', respuesta: 'Sí, el helio es un gas inerte, no tóxico y no inflamable. Es completamente seguro para eventos en interiores, incluyendo celebraciones con niños.' },
  { pregunta: '¿Ofrecen paquetes combinados con helio y decoración de aire?', respuesta: 'Sí, frecuentemente combinamos producciones de helio con arcos, columnas o backdrops. Al contratar producción completa de helio junto con otro servicio, ofrecemos un descuento especial sobre el precio total.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '44',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La producción completa de globos con helio es nuestro servicio integral de decoración flotante para eventos que requieren un impacto máximo. Con más de 100 globos distribuidos en techo, bouquets y arreglos especiales, transformamos todo el espacio aéreo de tu celebración.</p>
      <p>Este paquete incluye diseño personalizado de la distribución de helio, todos los tipos de globos disponibles (latex, chrome, foil, confeti), instalación profesional, coordinación con tu venue y desmontaje posterior. Es la opción para bodas, galas y eventos que merecen una decoración aérea completa.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Producción Completa de Globos con Helio: Decoración Aérea Total</h2>
        <p>La producción completa de globos con helio transforma el espacio aéreo de tu evento en una experiencia visual envolvente. Con más de 100 globos flotantes distribuidos estratégicamente, cada rincón del salón se llena de color, movimiento y magia que fascina a todos los invitados.</p>
        <p>El servicio integral incluye techo flotante con cintas de caída, bouquets de mesa coordinados, arreglos especiales para áreas fotográficas y elementos sorpresa como sueltas de globos biodegradables. Todo se planifica en una sesión de diseño previa donde definimos colores, distribución y momentos clave.</p>
        <p>Las producciones completas de helio son el servicio premium para bodas en salones de Huixquilucan, XV años en haciendas de Tlalpan y eventos corporativos en centros de convenciones de CDMX. Nuestro equipo de 3-4 especialistas se encarga de toda la logística, desde el transporte del helio hasta el desmontaje final.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
