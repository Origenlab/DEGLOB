---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'centros-de-mesa')!;
const paquete = servicio.paquetes.find(p => p.slug === 'paquete-20-mesas')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'paquete-20-mesas');

const faqItems = [
  { pregunta: '¿El diseño premium en qué se diferencia del básico?', respuesta: 'El diseño premium incluye globos de mayor variedad (chrome, confeti, doble stuffed), cintas de raso, elementos adicionales como mini flores y un peso decorativo más elaborado que complementa la temática.' },
  { pregunta: '¿Pueden hacer centros diferentes para la mesa principal?', respuesta: 'Sí, podemos diseñar un centro de mesa especial más grande para la mesa de honor o la mesa de novios, diferenciándola del resto con un arreglo premium que destaque.' },
  { pregunta: '¿Los 20 centros incluyen coordinación con el venue?', respuesta: 'Sí, nos comunicamos con el salón o restaurante para coordinar horarios de acceso, ubicación de mesas y cualquier restricción del espacio. Esto garantiza una instalación eficiente y sin contratiempos.' },
  { pregunta: '¿Qué tipo de eventos necesitan 20 centros de mesa?', respuesta: 'Eventos de 150 a 200 invitados como bodas medianas, XV años, graduaciones y cenas corporativas suelen requerir 20 centros de mesa para cubrir todas las mesas del salón.' },
  { pregunta: '¿Puedo elegir el estilo del centro de mesa?', respuesta: 'Sí, ofrecemos estilos que van desde el clásico bouquet elevado hasta diseños orgánicos con globos de diferentes tamaños, centros con número o edad, y arreglos temáticos según tu evento.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '41',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de 20 centros de mesa con globos está diseñado para eventos medianos de 150 a 200 invitados. Con diseño premium que incluye mix de texturas, cintas especiales y confeti, cada centro eleva la decoración de tu boda, XV años o evento corporativo en CDMX.</p>
      <p>Cada arreglo premium combina globos chrome, pastel, confeti y foil en una composición más elaborada que incluye coordinación con tu venue para una instalación perfecta. Es la opción ideal para bodas, XV años y graduaciones que requieren una decoración de mesa uniforme y sofisticada.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Centros de Mesa Premium para 20 Mesas: Decoración Uniforme y Sofisticada</h2>
        <p>Cuando tu evento requiere cubrir 20 mesas con una decoración uniforme y de calidad premium, este paquete es la respuesta. Los centros de mesa premium utilizan una variedad más amplia de globos, incluyendo acabados chrome metálico, confeti dorado, double stuffed y foil temáticos que reflejan la luz y crean un ambiente sofisticado.</p>
        <p>Cada centro se diseña con atención al detalle: cintas de raso coordinadas, pesos decorativos temáticos y elementos complementarios como mini flores o confeti de mesa. La coherencia visual entre los 20 centros crea una imagen impecable que tus invitados notarán desde el momento en que se sienten.</p>
        <p>Este paquete incluye coordinación con tu venue para acceder al salón con tiempo suficiente y colocar cada centro en la mesa correcta según el plano de distribución. Es el más solicitado para bodas en salones de Huixquilucan, XV años en haciendas y graduaciones en hoteles de CDMX.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
