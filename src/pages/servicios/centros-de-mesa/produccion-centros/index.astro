---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'centros-de-mesa')!;
const paquete = servicio.paquetes.find(p => p.slug === 'produccion-centros')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'produccion-centros');

const faqItems = [
  { pregunta: '¿Qué incluye la producción completa de centros de mesa?', respuesta: 'Incluye 40 o más centros de mesa con diseño integral, todos los acabados premium disponibles, elementos decorativos especiales, instalación y desmontaje completo, y coordinación total con tu equipo de organización.' },
  { pregunta: '¿Pueden cubrir más de 40 mesas?', respuesta: 'Sí, la producción completa se adapta a cualquier cantidad de mesas. Hemos cubierto eventos de hasta 80 mesas. El precio se ajusta proporcionalmente según la cantidad exacta que necesites.' },
  { pregunta: '¿Los centros pueden incluir iluminación LED?', respuesta: 'Sí, en la producción completa podemos integrar luces LED pequeñas dentro de globos transparentes que crean un efecto luminoso elegante, ideal para eventos nocturnos y galas.' },
  { pregunta: '¿Incluyen centros especiales para la mesa de honor?', respuesta: 'Sí, siempre diseñamos un centro premium más elaborado para la mesa principal, de novios o de honor. Este centro destaca del resto y funciona como pieza central de toda la decoración de mesas.' },
  { pregunta: '¿Coordinan con mi wedding planner?', respuesta: 'Sí, nos integramos al equipo de proveedores y coordinamos directamente con tu wedding planner o coordinador de eventos para asegurar que todo fluya según el timeline establecido.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '58',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La producción completa de centros de mesa es nuestro servicio integral para eventos de gran escala que requieren 40 o más mesas decoradas con globos premium. Incluye diseño integral, todos los acabados disponibles, instalación y desmontaje con coordinación total.</p>
      <p>Este paquete está diseñado para bodas de lujo, galas corporativas y celebraciones de gran formato donde cada mesa debe lucir impecable. Incluimos centros especiales para mesas de honor, opciones de iluminación LED y coordinación directa con tu equipo de organización.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Producción Completa de Centros de Mesa: Decoración de Gran Formato</h2>
        <p>La producción completa de centros de mesa con globos está diseñada para los eventos más grandes y exigentes de la CDMX. Con 40 o más mesas cubiertas, cada centro de mesa recibe el mismo nivel de atención y calidad premium que define nuestra marca.</p>
        <p>El servicio integral incluye centros diferenciados para mesas de honor, opciones de iluminación LED integrada para eventos nocturnos, y la posibilidad de crear hasta 5 variaciones de diseño que se distribuyen estratégicamente. Todo se planifica en sesiones de diseño previas con aprobación de muestras.</p>
        <p>Nuestro equipo de 4-5 decoradores se moviliza para instalaciones de esta magnitud, coordinando directamente con el wedding planner o coordinador del evento. Las producciones completas son el estándar para bodas en haciendas, galas en hoteles cinco estrellas y eventos corporativos de marca.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
