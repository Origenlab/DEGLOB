---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'globos-gigantes')!;
const paquete = servicio.paquetes.find(p => p.slug === 'produccion-gigantes')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'produccion-gigantes');

const faqItems = [
  { pregunta: '¿Qué incluye la producción completa de globos gigantes?', respuesta: 'Incluye 6 o más globos gigantes de 3 pies con diseño personalizado, todos los acabados disponibles (confeti, borlas, tassels), instalación completa y coordinación con los tiempos de tu evento.' },
  { pregunta: '¿Qué acabados están disponibles?', respuesta: 'Ofrecemos globos gigantes transparentes con confeti, globos opacos de colores sólidos, globos con borlas y tassels de papel, globos con cintas de raso y globos con relleno de plumas para un efecto ultra elegante.' },
  { pregunta: '¿Pueden crear una instalación aérea con globos gigantes?', respuesta: 'Sí, podemos crear techos o cortinas con globos gigantes flotantes (con helio) combinados con globos estándar para una experiencia aérea única. Este tipo de instalación es ideal para eventos VIP.' },
  { pregunta: '¿Cuántos globos gigantes se necesitan para un evento grande?', respuesta: 'Para un impacto significativo en un evento de 100+ personas, recomendamos mínimo 6 globos gigantes distribuidos en puntos estratégicos. Para eventos más grandes podemos usar 10 o más.' },
  { pregunta: '¿El precio incluye todo?', respuesta: 'Sí, el precio de $10,000 MXN incluye todos los globos, confeti premium, borlas, cintas, estructuras si se requieren, transporte, instalación profesional y coordinación con tu evento.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '54',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La producción completa de globos gigantes es nuestro servicio premium con 6 o más globos de 3 pies diseñados y distribuidos estratégicamente en tu evento. Con todos los acabados disponibles, confeti y borlas premium, cada globo es una pieza de arte en CDMX.</p>
      <p>Este paquete es para eventos que merecen una decoración de impacto máximo: bodas de lujo, lanzamientos de marca, galas corporativas y celebraciones exclusivas. Incluye diseño personalizado, instalación profesional y coordinación completa con tu equipo.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Producción Completa de Globos Gigantes: Arte Aéreo para tu Evento</h2>
        <p>La producción completa de globos gigantes lleva la decoración con globos a su máxima expresión. Con 6 o más globos de 3 pies distribuidos estratégicamente, cada pieza se convierte en un elemento decorativo que impacta por su tamaño, color y acabados premium.</p>
        <p>Las posibilidades incluyen instalaciones aéreas con globos flotantes de helio, composiciones de piso con pedestales elegantes, cortinas de globos gigantes con cintas de caída, y combinaciones que integran todos los acabados: confeti, borlas, plumas y tassels de papel de seda.</p>
        <p>Este servicio premium es el elegido para bodas destination, fiestas de celebridades, lanzamientos de producto y eventos corporativos VIP en los venues más exclusivos de la CDMX. Nuestro equipo se encarga de cada detalle, desde el diseño creativo hasta la instalación y el desmontaje final.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
