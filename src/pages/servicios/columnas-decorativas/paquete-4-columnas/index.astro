---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'columnas-decorativas')!;
const paquete = servicio.paquetes.find(p => p.slug === 'paquete-4-columnas')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'paquete-4-columnas');

const faqItems = [
  { pregunta: '¿Qué diseño puedo lograr con 4 columnas de globos?', respuesta: 'Con 4 columnas puedes crear un pasillo de entrada espectacular, enmarcar un escenario, delimitar la pista de baile o decorar las esquinas de un área específica. Es el paquete más solicitado para XV años y recepciones de boda.' },
  { pregunta: '¿Las 4 columnas pueden tener colores diferentes entre sí?', respuesta: 'Sí, puedes elegir hasta 3 colores combinados. Podemos hacer todas iguales o alternar diseños entre pares para crear un efecto visual más dinámico.' },
  { pregunta: '¿Qué incluye el remate superior decorativo?', respuesta: 'El remate superior es una composición de globos de diferentes tamaños que corona cada columna, dándole un acabado profesional. Puede ser un bouquet esférico, una estrella foil o un diseño orgánico según tu preferencia.' },
  { pregunta: '¿Cuánto espacio necesito para las 4 columnas?', respuesta: 'Cada columna ocupa aproximadamente 60cm de diámetro en su base. Para un pasillo, recomendamos separar cada par entre 1.5 y 2 metros. Te asesoramos sobre la mejor distribución según tu venue.' },
  { pregunta: '¿La instalación de 4 columnas está incluida en el precio?', respuesta: 'Sí, el precio de $5,500 MXN incluye transporte, instalación profesional y todo el material necesario. Nuestro equipo se encarga del montaje completo en cualquier punto de la CDMX.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '33',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>El paquete de 4 columnas decorativas de globos es perfecto para crear pasillos impactantes en entradas de salones, delimitar pistas de baile o enmarcar escenarios en XV años, bodas y eventos corporativos en la Ciudad de México.</p>
      <p>Cada columna mide 1.8 metros de altura con remate superior decorativo incluido. Trabajamos con hasta 3 colores en acabados premium de latex, chrome y pastel sobre bases reforzadas que garantizan estabilidad durante toda tu celebración.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Pasillos y Marcos Espectaculares con 4 Columnas de Globos</h2>
        <p>Un juego de 4 columnas de globos transforma cualquier espacio en un escenario fotogénico e impactante. Este paquete es el favorito para crear pasillos de entrada en salones de XV años, recepciones de boda y eventos corporativos en la CDMX, donde las columnas guían a los invitados hacia el área principal con un efecto visual memorable.</p>
        <p>Las 4 columnas de 1.8 metros incluyen remates superiores decorativos que coronan cada pieza con un bouquet de globos. La combinación de hasta 3 colores permite crear diseños que van desde lo clásico y elegante hasta lo moderno y llamativo, adaptándose a cualquier paleta de colores y temática.</p>
        <p>La estructura reforzada de cada columna incluye bases pesadas que mantienen la estabilidad incluso en jardines y terrazas. Nuestro equipo profesional se encarga de la instalación completa, llegando con 2 horas de anticipación para que todo esté perfecto cuando lleguen tus invitados.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
