---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'figuras-personalizadas')!;
const paquete = servicio.paquetes.find(p => p.slug === 'produccion-figuras')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'produccion-figuras');

const faqItems = [
  { pregunta: '¿Cuántas figuras incluye el paquete de producción de figuras?', respuesta: 'El paquete de producción incluye múltiples figuras de globos diseñadas para crear una experiencia visual completa. La cantidad exacta depende del diseño y la complejidad de cada figura, pero generalmente incluye entre 3 y 5 piezas de gran formato.' },
  { pregunta: '¿En qué tipo de eventos se recomienda la producción de figuras?', respuesta: 'La producción de figuras es ideal para eventos grandes como fiestas de XV años, cumpleaños temáticos con decoración completa, eventos corporativos, lanzamientos de marca y celebraciones especiales en CDMX que requieren un impacto visual a gran escala.' },
  { pregunta: '¿Se puede personalizar la temática de todas las figuras?', respuesta: 'Sí, todas las figuras se diseñan bajo una misma temática que tú eliges. Podemos crear mundos completos de personajes, escenarios temáticos o composiciones artísticas que transformen por completo el espacio de tu evento en la Ciudad de México.' },
  { pregunta: '¿Cuánto espacio se necesita para la producción de figuras?', respuesta: 'Para una producción completa recomendamos un espacio mínimo de 4 metros de ancho por 3 metros de profundidad. Nuestro equipo realiza una visita previa al venue en CDMX para evaluar el espacio y diseñar la distribución óptima de las figuras.' },
  { pregunta: '¿Con cuánta anticipación debo contratar la producción de figuras?', respuesta: 'Recomendamos reservar con mínimo 15 días de anticipación debido a la complejidad del proyecto. Para eventos en temporada alta de cumpleaños y fiestas temáticas en CDMX, sugerimos agendar con al menos 3 semanas de antelación.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '58',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>Transforma tu evento en una experiencia visual inolvidable con nuestra producción completa de figuras de globos. Este paquete premium incluye múltiples figuras personalizadas que crean un escenario temático integral para fiestas de cumpleaños, XV años, eventos corporativos y celebraciones de gran formato en la Ciudad de México.</p>
      <p>DEGLOB ofrece el servicio más completo de producción de figuras de globos en CDMX. Nuestro equipo de artistas en globoflexia trabaja de forma coordinada para diseñar, elaborar e instalar composiciones espectaculares que convierten cualquier espacio en un mundo temático. Ideal para quienes buscan una decoración de alto impacto.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Producción completa de figuras de globos para eventos en CDMX</h2>
        <p>Nuestro paquete de producción de figuras es la solución integral para quienes desean una decoración de globos a gran escala. Diseñado para fiestas de XV años, cumpleaños temáticos, eventos corporativos y celebraciones especiales en la Ciudad de México, este servicio incluye la creación de múltiples figuras que trabajan en conjunto para transformar tu espacio en un escenario mágico.</p>
        <p>La producción abarca desde la conceptualización del diseño hasta la instalación final. Nuestro equipo de artistas trabaja de manera coordinada para crear composiciones coherentes que pueden incluir personajes, números, letras, arcos y elementos decorativos complementarios. Cada pieza está elaborada con globos de primera calidad que garantizan durabilidad y colores vibrantes durante todo el evento.</p>
        <p>Este paquete premium incluye visita previa al lugar del evento para evaluar el espacio, diseño personalizado de la composición completa, elaboración artesanal de todas las figuras e instalación profesional. Cubrimos toda la CDMX y zona metropolitana, adaptándonos a cualquier tipo de venue: salones de fiestas, jardines, terrazas, hoteles y espacios corporativos.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
