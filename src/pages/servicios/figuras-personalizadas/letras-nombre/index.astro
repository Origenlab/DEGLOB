---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'figuras-personalizadas')!;
const paquete = servicio.paquetes.find(p => p.slug === 'letras-nombre')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'letras-nombre');

const faqItems = [
  { pregunta: '¿Cuántas letras incluye el paquete de letras con nombre?', respuesta: 'El paquete incluye hasta 6 letras. Si necesitas más letras para un nombre más largo o una frase, podemos cotizarte un precio especial. Cada letra es elaborada artesanalmente con globos de alta calidad.' },
  { pregunta: '¿Qué tamaño tienen las letras de globos?', respuesta: 'Cada letra tiene una altura proporcional que varía entre 80 cm y 1 metro, dependiendo del diseño y la tipografía elegida. El conjunto completo crea un impacto visual espectacular en cualquier fiesta de cumpleaños o XV años en CDMX.' },
  { pregunta: '¿Se pueden hacer letras con diferentes estilos de tipografía?', respuesta: 'Sí, ofrecemos diversos estilos de tipografía: desde letras redondeadas y divertidas para fiestas infantiles, hasta estilos elegantes y sofisticados para XV años, bodas y eventos corporativos en la Ciudad de México.' },
  { pregunta: '¿Puedo elegir colores diferentes para cada letra?', respuesta: 'Por supuesto. Puedes elegir un color diferente para cada letra, crear un degradado de colores o mantener un tono uniforme. Nos adaptamos a la paleta de tu fiesta temática para lograr una decoración coherente.' },
  { pregunta: '¿Las letras de globos se pueden colocar en exteriores?', respuesta: 'Sí, nuestras letras de globos se pueden instalar tanto en interiores como en exteriores. Para eventos al aire libre en CDMX, utilizamos técnicas especiales de anclaje y globos resistentes a las condiciones exteriores.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '53',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>Personaliza tu celebración con letras gigantes de globos que deletrean el nombre del festejado. Nuestro paquete de letras con nombre incluye hasta 6 letras elaboradas artesanalmente, perfectas para cumpleaños, XV años, baby showers y fiestas temáticas en la Ciudad de México. Un detalle que transforma cualquier espacio en un escenario único y personalizado.</p>
      <p>En DEGLOB creamos letras de globos con acabados profesionales que destacan en cualquier evento. Cada letra es diseñada para combinar con tu decoración, ofreciendo una experiencia visual impactante que tus invitados recordarán. Servicio completo con instalación incluida en CDMX y zona metropolitana.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Letras con nombre de globos para fiestas y celebraciones en CDMX</h2>
        <p>Las letras gigantes de globos con el nombre del festejado son uno de los elementos decorativos más populares para cumpleaños, XV años y baby showers en la Ciudad de México. Este paquete incluye hasta 6 letras artesanales que crean un letrero personalizado, perfecto como fondo para fotos y como pieza central de la decoración.</p>
        <p>Nuestro equipo de artistas en globoflexia domina diferentes técnicas para crear letras con acabados sorprendentes: desde estilos orgánicos con texturas variadas hasta diseños geométricos y elegantes. Utilizamos globos de látex premium en más de 50 tonalidades, lo que nos permite lograr combinaciones exactas con la paleta de colores de tu fiesta temática.</p>
        <p>El servicio incluye diseño personalizado, elaboración artesanal e instalación profesional en cualquier punto de la CDMX y zona metropolitana. Ya sea en un salón de fiestas, jardín, restaurante o tu propio hogar, nuestro equipo se encarga de que las letras queden perfectamente colocadas y listas para brillar en tu celebración.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
