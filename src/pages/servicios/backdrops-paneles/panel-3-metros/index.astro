---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'backdrops-paneles')!;
const paquete = servicio.paquetes.find(p => p.slug === 'panel-3-metros')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'panel-3-metros');

const faqItems = [
  { pregunta: '¿Qué diferencia hay entre el panel de 2 y 3 metros?', respuesta: 'El panel de 3 metros (3m × 2.5m) ofrece mayor cobertura y un diseño orgánico más elaborado con hasta 5 colores. Es ideal para eventos más grandes donde el fondo fotográfico debe impactar a mayor distancia.' },
  { pregunta: '¿El diseño orgánico qué significa?', respuesta: 'El diseño orgánico utiliza globos de diferentes tamaños (5, 11 y 16 pulgadas) distribuidos de forma asimétrica y natural, creando texturas y volúmenes que dan un aspecto artístico y moderno al panel.' },
  { pregunta: '¿Puedo usar el panel de 3 metros para una boda?', respuesta: 'Absolutamente. El panel de 3 metros es uno de nuestros productos más solicitados para bodas, ya sea como fondo del altar civil, backdrop de la mesa de novios o como photobooth para los invitados.' },
  { pregunta: '¿Cuántas personas caben en una foto frente al panel?', respuesta: 'El panel de 3×2.5 metros permite fotos grupales de hasta 6-8 personas cómodamente. Es ideal para fotos familiares, de damas de honor y grupos de amigos.' },
  { pregunta: '¿Se puede combinar con flores naturales?', respuesta: 'Sí, podemos integrar flores artificiales de alta calidad o coordinar con tu florista para incluir flores naturales en el diseño del panel. Esto agrega un toque de elegancia adicional.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '44',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>El panel de globos de 3 metros es nuestro backdrop más solicitado para bodas, XV años y eventos donde el fondo fotográfico debe ser el protagonista. Con un diseño orgánico de 3×2.5 metros y hasta 5 colores, crea fondos espectaculares para fotos grupales e individuales.</p>
      <p>Cada panel se diseña con una composición orgánica que combina globos de múltiples tamaños y texturas sobre una estructura reforzada. El resultado es un muro de globos artístico y fotogénico que eleva la decoración de cualquier evento en la Ciudad de México.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Backdrop de Globos de 3 Metros para Bodas y Eventos</h2>
        <p>El panel de globos de 3 metros se ha convertido en el elemento decorativo estrella para bodas y XV años en la Ciudad de México. Con sus dimensiones de 3×2.5 metros, este backdrop ofrece un fondo fotográfico generoso donde grupos de hasta 8 personas pueden tomarse fotos espectaculares.</p>
        <p>El diseño orgánico es la firma de este paquete: globos de diferentes tamaños se distribuyen de forma asimétrica creando volúmenes, texturas y profundidad visual. La combinación de hasta 5 colores permite crear degradados, contrastes y composiciones únicas que se adaptan a cualquier temática.</p>
        <p>Este panel es especialmente popular para bodas en jardines de Xochimilco, XV años en salones de Satélite, y sesiones fotográficas profesionales en estudios de la CDMX. La estructura reforzada soporta el peso de cientos de globos y se mantiene firme durante todo el evento.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
