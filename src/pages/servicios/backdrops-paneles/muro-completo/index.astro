---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'backdrops-paneles')!;
const paquete = servicio.paquetes.find(p => p.slug === 'muro-completo')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'muro-completo');

const faqItems = [
  { pregunta: '¿Qué dimensiones tiene el muro completo?', respuesta: 'El muro completo tiene un ancho de 4 metros o más y una altura de 2.5 metros. Es una superficie amplia que cubre visualmente toda una pared, creando un impacto decorativo importante en cualquier salón de eventos.' },
  { pregunta: '¿En qué tipo de eventos se recomienda el muro completo?', respuesta: 'Es ideal para bodas grandes, recepciones en salones amplios, eventos corporativos con escenario, lanzamientos de marca, fiestas de XV años con muchos invitados y cualquier celebración donde se busque un fondo fotográfico de gran escala.' },
  { pregunta: '¿Se puede instalar el muro en cualquier salón?', respuesta: 'Sí, nuestras estructuras son autoportantes y no necesitan fijarse a las paredes del venue. Solo necesitamos un espacio de al menos 5 metros de ancho y 3 metros de alto. Realizamos una visita previa o revisamos fotos del lugar para confirmar la viabilidad.' },
  { pregunta: '¿Qué incluye el paquete de muro completo?', respuesta: 'Incluye diseño personalizado, fabricación de la estructura y cobertura, traslado, montaje profesional, permanencia durante todo el evento y desmontaje posterior. Todo dentro de la CDMX sin costos adicionales.' },
  { pregunta: '¿Se puede combinar el muro con otros elementos decorativos?', respuesta: 'Absolutamente. El muro completo se puede complementar con iluminación, letras gigantes, arreglos florales naturales o artificiales, cortinas de luces y otros elementos para crear una experiencia visual completa.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '52',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>El muro completo es nuestra propuesta de mayor impacto visual para eventos en la Ciudad de México. Con más de 4 metros de ancho y 2.5 metros de alto, este backdrop transforma por completo cualquier espacio y se convierte en el centro de atención de bodas, fiestas de XV años y eventos corporativos de gran formato.</p>
      <p>Nuestro equipo de producción diseña, fabrica e instala el muro directamente en tu venue. Trabajamos con los mejores materiales del mercado para asegurar un resultado que impresione a tus invitados y luzca perfecto en cada foto y video de tu evento.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Transforma tu evento con un muro de gran formato</h2>
        <p>El muro completo es la elección de quienes buscan crear una experiencia visual inolvidable. Con más de 4 metros de ancho, este backdrop cubre toda una pared del salón y se convierte en el elemento decorativo principal de tu celebración, perfecto para la pista de baile, el área de fotos o como fondo de escenario.</p>
        <p>Este paquete es especialmente popular en bodas de gran formato, eventos empresariales con escenario, lanzamientos de producto, fiestas de XV años con temática elaborada y cualquier ocasión donde se necesite un fondo que impresione. Cada muro se diseña desde cero para que sea único y acorde a tu visión.</p>
        <p>Operamos en toda la Ciudad de México y zona metropolitana. Nuestro equipo llega con anticipación al evento, realiza el montaje completo y se encarga del desmontaje al finalizar, garantizando una experiencia sin complicaciones para ti y los organizadores del evento.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
