---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'backdrops-paneles')!;
const paquete = servicio.paquetes.find(p => p.slug === 'muro-completo')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'muro-completo');

const faqItems = [
  { pregunta: '¿Qué tamaño tiene el muro completo de globos?', respuesta: 'El muro completo mide 4 metros o más de ancho por 2.5 metros de alto, cubriendo una superficie impresionante que funciona como escenario principal de tu evento. Es nuestro panel más grande y espectacular.' },
  { pregunta: '¿Qué tipo de globos se usan en el muro completo?', respuesta: 'Utilizamos una combinación premium de globos chrome metálico, pastel mate, confeti transparente, latex estándar y foil temáticos. Esta mezcla de texturas crea un muro con profundidad y brillo excepcionales.' },
  { pregunta: '¿El muro incluye flores y follaje?', respuesta: 'Sí, el paquete de muro completo incluye flores artificiales premium y follaje que se integran entre los globos para crear un diseño más sofisticado y orgánico. Es ideal para bodas y eventos de gala.' },
  { pregunta: '¿Cuánto tiempo toma instalar el muro completo?', respuesta: 'La instalación del muro completo requiere entre 3 y 4 horas con un equipo de 2-3 decoradores. Coordinamos el horario de acceso con tu venue para que todo esté listo a tiempo.' },
  { pregunta: '¿Se puede colocar texto o letreros sobre el muro?', respuesta: 'Sí, podemos integrar letras de neón, acrílico o foil sobre el muro de globos. Nombres de los novios, edad del festejado o logotipos corporativos son las opciones más populares.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '34',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>El muro completo de globos es nuestra pieza decorativa más impactante: más de 4 metros de ancho por 2.5 metros de alto con diseño premium que combina globos chrome, pastel, confeti, flores y follaje. Es el escenario principal perfecto para bodas de lujo y eventos exclusivos en CDMX.</p>
      <p>Cada muro se diseña como una obra de arte efímera, combinando cientos de globos en diferentes tamaños, texturas y acabados con elementos florales. El resultado es un fondo fotográfico que impresiona tanto en persona como en las redes sociales de tus invitados.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Muro Completo de Globos: La Pieza Central de tu Evento</h2>
        <p>El muro completo de globos es la declaración decorativa más poderosa que puedes hacer en tu evento. Con más de 4 metros de ancho y 2.5 metros de alto, este backdrop se convierte en el telón de fondo de las fotos más compartidas de la noche y el punto focal que define la estética de toda la celebración.</p>
        <p>Lo que distingue este paquete es la combinación premium de materiales: globos chrome que reflejan la luz, globos pastel que aportan suavidad, globos de confeti que agregan brillo, y elementos florales que dan un toque natural y sofisticado. Cada muro utiliza entre 300 y 500 globos seleccionados individualmente.</p>
        <p>El muro completo es la opción preferida para bodas en haciendas de CDMX, galas corporativas en hoteles de Polanco y eventos exclusivos en terrazas de Santa Fe. Nuestro equipo de decoradores expertos se encarga de todo el proceso, desde el diseño hasta la instalación y retiro.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
