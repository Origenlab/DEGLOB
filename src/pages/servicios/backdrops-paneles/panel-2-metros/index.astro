---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'backdrops-paneles')!;
const paquete = servicio.paquetes.find(p => p.slug === 'panel-2-metros')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'panel-2-metros');

const faqItems = [
  { pregunta: '¿Para qué se usa un panel de globos de 2 metros?', respuesta: 'Un panel de 2×2 metros es perfecto como fondo fotográfico para baby showers, mesas de regalos, candy bars y rincones de fotos en cumpleaños. Su tamaño compacto se adapta a espacios reducidos sin perder impacto visual.' },
  { pregunta: '¿El panel es autoportante o necesita pared?', respuesta: 'Nuestros paneles incluyen estructura autoportante que se sostiene sin necesidad de pared. Puedes colocarlo en cualquier punto del salón, jardín o terraza sin preocuparte por el soporte.' },
  { pregunta: '¿Puedo agregar letras o números al panel?', respuesta: 'Sí, podemos integrar letras foil, números o mensajes personalizados sobre el panel de globos. Este servicio tiene un costo adicional según la cantidad de elementos.' },
  { pregunta: '¿Cuánto tiempo dura un panel de globos?', respuesta: 'Un panel de globos de aire tiene una duración de 24 a 48 horas en interiores. Recomendamos instalar máximo 4 horas antes del evento para garantizar su mejor aspecto.' },
  { pregunta: '¿La instalación del panel está incluida?', respuesta: 'Sí, el precio de $3,500 MXN incluye la instalación profesional en cualquier punto de la CDMX. Nuestro equipo se encarga del armado completo de la estructura y los globos.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '59',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>El panel de globos de 2 metros es la opción más solicitada como fondo fotográfico para baby showers, candy bars y cumpleaños en la Ciudad de México. Con cobertura completa de 2×2 metros y estructura autoportante, crea el escenario perfecto para fotos memorables.</p>
      <p>Nuestro equipo utiliza globos premium en la paleta de colores que elijas, construyendo una composición orgánica o uniforme sobre estructura autoportante que se coloca en cualquier espacio de tu evento sin necesidad de paredes de apoyo.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Panel de Globos de 2 Metros: Fondo Fotográfico Perfecto</h2>
        <p>El panel de globos de 2 metros es el complemento decorativo ideal para quienes buscan un fondo fotográfico impactante sin necesidad de una inversión mayor. Este tamaño se ha convertido en el favorito para baby showers y candy bars en la CDMX por su capacidad de transformar cualquier rincón en un spot instagrameable.</p>
        <p>La estructura autoportante permite colocar el panel en cualquier punto de tu evento: junto a la mesa de dulces, detrás de la mesa principal o como punto focal para selfies. Los globos se colocan en una composición densa que cubre completamente los 2×2 metros, creando un muro de color y textura.</p>
        <p>Trabajamos con globos de latex en acabados mate, pastel y chrome que se combinan según tu paleta de colores. La instalación toma aproximadamente 1.5 horas y nuestro equipo se encarga de todo el montaje en zonas como Polanco, Condesa, Del Valle, Coyoacán y toda la CDMX.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
