---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'backdrops-paneles')!;
const paquete = servicio.paquetes.find(p => p.slug === 'produccion-backdrops')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'produccion-backdrops');

const faqItems = [
  { pregunta: '¿Qué incluye la producción completa de backdrops?', respuesta: 'Incluye múltiples paneles decorativos, diseño integral con todos los acabados disponibles, instalación y desmontaje profesional, coordinación con tu fotógrafo y asesoría de diseño personalizada para crear una experiencia visual cohesiva.' },
  { pregunta: '¿Cuántos paneles incluye la producción completa?', respuesta: 'La producción incluye 2 o más paneles de diferentes tamaños distribuidos estratégicamente en tu evento: uno principal y uno o más secundarios para diferentes áreas como la entrada, el photobooth y la mesa de dulces.' },
  { pregunta: '¿Coordinan con mi fotógrafo?', respuesta: 'Sí, como parte del servicio nos comunicamos con tu fotógrafo para garantizar que la iluminación, ubicación y acabados de los paneles sean óptimos para las fotos. Esto asegura resultados profesionales en las imágenes.' },
  { pregunta: '¿Cuánto tiempo antes del evento necesitan llegar?', respuesta: 'Para producciones completas llegamos entre 4 y 6 horas antes del evento. El equipo de 3-4 decoradores trabaja de forma coordinada para montar todos los paneles a tiempo.' },
  { pregunta: '¿Pueden crear backdrops temáticos?', respuesta: 'Sí, en la producción completa diseñamos backdrops temáticos que pueden incluir formas especiales, letras gigantes, marcos fotográficos integrados y cualquier elemento que imagine para su evento.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '43',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La producción completa de backdrops y paneles de globos es nuestro servicio integral para eventos que requieren múltiples fondos decorativos. Incluye diseño de varios paneles, todos los acabados premium, instalación y desmontaje, y coordinación con tu fotógrafo.</p>
      <p>Este paquete transforma tu evento con múltiples puntos fotogénicos distribuidos estratégicamente: un backdrop principal para la mesa de novios o festejado, paneles secundarios para el photobooth y la mesa de dulces, y elementos decorativos complementarios que unifican toda la estética.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Producción Completa de Backdrops para Eventos de Alto Nivel</h2>
        <p>La producción completa de backdrops es nuestro servicio más ambicioso en materia de fondos decorativos con globos. Diseñamos e instalamos múltiples paneles que crean una experiencia visual envolvente en tu evento, desde la entrada hasta los rincones más íntimos de la celebración.</p>
        <p>El servicio comienza con una sesión de diseño donde definimos juntos la visión creativa. Creamos un moodboard con propuestas de colores, estilos y distribución de paneles. Coordinamos con tu fotógrafo y wedding planner para asegurar que cada backdrop esté ubicado en el punto óptimo para las mejores fotos.</p>
        <p>Las producciones completas de backdrops son el servicio estrella para bodas destination en hoteles de la Riviera, XV años en los salones más exclusivos de CDMX y eventos corporativos de lanzamiento de marca. El precio incluye todo: diseño, materiales, instalación, desmontaje y coordinación integral.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
