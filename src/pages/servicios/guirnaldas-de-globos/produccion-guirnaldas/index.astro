---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'guirnaldas-de-globos')!;
const paquete = servicio.paquetes.find(p => p.slug === 'produccion-guirnaldas')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'produccion-guirnaldas');

const faqItems = [
  { pregunta: '¿Qué incluye la producción completa de guirnaldas?', respuesta: 'Incluye 15 o más metros lineales de guirnaldas distribuidas por todo tu evento, diseño integral, todos los acabados premium, instalación y desmontaje profesional, coordinación con el venue y asesoría de diseño personalizada.' },
  { pregunta: '¿Pueden distribuir las guirnaldas en diferentes áreas?', respuesta: 'Sí, la producción completa permite distribuir los metros de guirnalda en múltiples áreas: entrada, mesa principal, escenario, escaleras, photobooth y cualquier espacio que necesite decoración.' },
  { pregunta: '¿La asesoría de diseño incluye visita al venue?', respuesta: 'Sí, para producciones completas realizamos una visita al venue donde medimos espacios, evaluamos puntos de fijación y diseñamos la distribución óptima de cada metro de guirnalda.' },
  { pregunta: '¿Cuántas personas instalan la producción completa?', respuesta: 'Un equipo de 3-4 decoradores se encarga de la instalación, que toma entre 4 y 6 horas dependiendo de la cantidad de áreas a cubrir y la complejidad de los accesos.' },
  { pregunta: '¿Incluye desmontaje después del evento?', respuesta: 'Sí, la producción completa incluye el desmontaje de todas las guirnaldas al finalizar tu evento, dejando el espacio limpio y sin residuos de la instalación.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '57',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La producción completa de guirnaldas de globos ofrece 15 o más metros de decoración orgánica distribuida por todo tu evento. Con diseño integral, todos los acabados premium, instalación y desmontaje, es el servicio para eventos que requieren cobertura total en CDMX.</p>
      <p>Este paquete transforma cada área de tu celebración con guirnaldas coordinadas: desde la entrada hasta el escenario principal, pasando por mesas, escaleras y rincones fotográficos. La asesoría de diseño incluye visita al venue para planificar la distribución perfecta.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Producción Completa de Guirnaldas: Cobertura Decorativa Total</h2>
        <p>La producción completa de guirnaldas es nuestro servicio de máxima cobertura en decoración lineal con globos. Con 15 o más metros distribuidos estratégicamente por todo el evento, cada área recibe su dosis de decoración coordinada y profesional.</p>
        <p>El proceso comienza con una visita al venue donde nuestro equipo evalúa los espacios, identifica los mejores puntos de fijación y diseña un plan de distribución que maximiza el impacto visual. Escaleras, barandales, marcos de puerta, mesas y escenarios se conectan visualmente a través de guirnaldas que fluyen orgánicamente.</p>
        <p>Las producciones completas son el estándar para bodas en haciendas que requieren cubrir múltiples áreas, XV años en salones con arquitectura compleja, y eventos corporativos de marca donde la decoración debe ser envolvente y coherente. Incluye instalación con equipo de 3-4 personas y desmontaje posterior.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
