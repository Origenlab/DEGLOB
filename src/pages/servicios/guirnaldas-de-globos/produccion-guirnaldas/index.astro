---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'guirnaldas-de-globos')!;
const paquete = servicio.paquetes.find(p => p.slug === 'produccion-guirnaldas')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'produccion-guirnaldas');

const faqItems = [
  { pregunta: '¿Qué incluye la producción completa de guirnaldas?', respuesta: 'La producción completa incluye 15 o más metros lineales de guirnaldas orgánicas, diseño integral personalizado, todos los acabados disponibles (chrome, pastel, confeti, mate), flores y follaje, instalación y desmontaje, coordinación directa con el venue y asesoría de diseño con nuestra directora creativa.' },
  { pregunta: '¿La producción completa cubre el desmontaje después del evento?', respuesta: 'Sí, a diferencia de los paquetes individuales, la producción completa incluye tanto la instalación como el desmontaje posterior al evento. Nuestro equipo regresa al venue al finalizar la celebración para retirar todas las guirnaldas y dejar el espacio limpio.' },
  { pregunta: '¿Pueden coordinarse con el venue y otros proveedores?', respuesta: 'Absolutamente. La producción completa incluye coordinación directa con el administrador del venue para horarios de montaje, accesos y restricciones. También nos coordinamos con wedding planners, fotógrafos y otros proveedores para asegurar que todo esté perfecto.' },
  { pregunta: '¿Qué tan grande es un montaje de 15+ metros de guirnaldas?', respuesta: '15 metros o más de guirnaldas permiten decorar múltiples puntos de un evento: arco ceremonial, entrada del salón, barandal de escalera, mesa principal, photobooth y pista de baile. Es la cobertura total para bodas, XV años y eventos de gran formato en la CDMX.' },
  { pregunta: '¿Se puede personalizar completamente el diseño?', respuesta: 'Sí, la producción completa incluye una sesión de asesoría de diseño donde definimos paleta de colores, estilo (orgánico, estructurado, botánico), acabados y distribución de las guirnaldas en el espacio. Creamos un concepto visual integral que se adapta a la temática de tu evento.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '59',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La producción completa de guirnaldas de globos es nuestro servicio integral para bodas, XV años, graduaciones y eventos corporativos de gran formato en la CDMX. Con 15 o más metros de guirnaldas orgánicas, cubrimos múltiples puntos de decoración: arcos, escaleras, barandales, mesas, escenarios y entradas, todo con un diseño coherente y espectacular.</p>
      <p>Este paquete incluye asesoría de diseño personalizada, todos los acabados premium, flores y follaje, instalación y desmontaje completo, y coordinación directa con tu venue. Es la solución todo-incluido para quienes buscan una decoración de guirnaldas de globos impecable y sin preocupaciones en cualquier salón de la Ciudad de México.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Producción Completa de Guirnaldas: Decoración Integral para Tu Evento</h2>
        <p>La producción completa de guirnaldas es nuestro servicio más exclusivo y la opción preferida de wedding planners y organizadores de eventos de la CDMX. Con 15 o más metros de guirnaldas orgánicas, cubrimos todos los puntos clave de decoración: el arco ceremonial de la boda, la entrada del salón para XV años, los barandales de escalera en haciendas, la mesa principal, el photobooth y la pista de baile.</p>
        <p>El proceso comienza con una sesión de asesoría de diseño donde nuestra directora creativa define contigo la paleta de colores, el estilo visual y la distribución de las guirnaldas en el espacio. Trabajamos con todos los acabados disponibles: globos chrome para brillos metálicos, globos de confeti para texturas, globos pastel para suavidad y globos mate para elegancia sobria. Integramos flores naturales o artificiales y follaje selecto para un resultado botánico-orgánico de alto nivel.</p>
        <p>Nuestro equipo de producción se coordina directamente con el administrador de tu venue para definir horarios de montaje, accesos y puntos de fijación. La instalación se realiza de 3 a 5 horas antes del evento, y al finalizar la celebración regresamos para el desmontaje completo. Atendemos los venues más exclusivos de la CDMX: haciendas en Tlalpan, jardines en Coyoacán, salones en Polanco, terrazas en Santa Fe, fincas en Huixquilucan y espacios en toda la zona metropolitana.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
