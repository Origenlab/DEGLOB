---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'guirnaldas-de-globos')!;
const paquete = servicio.paquetes.find(p => p.slug === 'guirnalda-6-metros')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'guirnalda-6-metros');

const faqItems = [
  { pregunta: '¿La guirnalda de 6 metros incluye globos chrome?', respuesta: 'Sí, este paquete incluye globos chrome metálicos que aportan brillo y reflejan la luz del venue. Se combinan con globos pastel y latex para crear una composición con diferentes texturas y acabados.' },
  { pregunta: '¿Qué es el follaje opcional?', respuesta: 'Podemos agregar hojas y ramas artificiales de eucalipto, monstera o helecho entre los globos de la guirnalda. Esto da un toque natural y botánico que está muy de moda en bodas y eventos elegantes.' },
  { pregunta: '¿La guirnalda de 6 metros se puede dividir en dos?', respuesta: 'Sí, podemos cortar la guirnalda en dos secciones de 3 metros para decorar dos áreas diferentes de tu evento, como la entrada y la mesa de dulces.' },
  { pregunta: '¿Para qué tipo de evento es ideal esta guirnalda?', respuesta: 'La guirnalda de 6 metros es perfecta para decorar barandales de escaleras, marcos de escenarios, contornos de mesas principales y entradas de salón. Es el tamaño más popular para bodas y XV años.' },
  { pregunta: '¿Cuántos colores puedo usar?', respuesta: 'Puedes elegir hasta 5 colores diferentes, lo que permite crear degradados, composiciones multicolor o combinaciones bicolor más elegantes según la temática de tu evento.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '47',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La guirnalda de globos de 6 metros es nuestro tamaño más popular para bodas, XV años y eventos medianos en CDMX. Con mix de tamaños, hasta 5 colores, globos chrome incluidos y follaje opcional, crea decoraciones lineales espectaculares para escaleras, mesas y escenarios.</p>
      <p>Seis metros de globos orgánicos ofrecen la versatilidad de decorar áreas completas: desde barandales de escalera hasta el contorno de una mesa principal. Los globos chrome aportan brillo mientras los acabados pastel dan suavidad, creando contrastes visuales sofisticados.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Guirnalda de 6 Metros: La Favorita para Bodas y XV Años</h2>
        <p>La guirnalda de globos de 6 metros se ha consolidado como el tamaño más solicitado para bodas y XV años en la Ciudad de México. Con la longitud suficiente para decorar un barandal completo, el contorno de una mesa principal o la parte superior de un escenario, esta guirnalda transforma cualquier superficie lineal en una obra de arte.</p>
        <p>La inclusión de globos chrome en este paquete agrega una dimensión de brillo y reflejo que eleva la decoración. Combinados con globos pastel y latex en hasta 5 colores, se logran composiciones orgánicas con profundidad visual. El follaje opcional de eucalipto o monstera agrega un toque botánico que está en tendencia.</p>
        <p>Es la guirnalda favorita para bodas en jardines de Cuernavaca, XV años en salones de Naucalpan y eventos en terrazas de la Ciudad de México. Se puede instalar como una pieza continua de 6 metros o dividirla en dos secciones para cubrir diferentes áreas del evento.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
