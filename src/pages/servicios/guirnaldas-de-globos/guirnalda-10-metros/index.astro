---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'guirnaldas-de-globos')!;
const paquete = servicio.paquetes.find(p => p.slug === 'guirnalda-10-metros')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'guirnalda-10-metros');

const faqItems = [
  { pregunta: '¿Qué tipo de eventos requieren una guirnalda de 10 metros?', respuesta: 'La guirnalda de 10 metros es ideal para bodas, XV años, graduaciones y eventos corporativos que necesitan una decoración de gran impacto. Se utiliza para cubrir arcos de entrada completos, decorar escenarios, enmarcar pistas de baile y recorrer barandales largos en salones amplios de la CDMX.' },
  { pregunta: '¿Qué acabados incluye la guirnalda de 10 metros?', respuesta: 'Este paquete premium incluye globos chrome metálicos, globos pastel, globos de confeti y globos mate en colores ilimitados. Además, incorporamos flores naturales o artificiales y follaje para un resultado espectacular y digno de revista.' },
  { pregunta: '¿La guirnalda de 10 metros puede cubrir un arco completo?', respuesta: 'Sí, 10 metros lineales son suficientes para crear un arco completo de 2.5 a 3 metros de alto por 3 metros de ancho, o para decorar un tramo largo de barandal, mesa imperial o escenario. Se adapta a la geometría de tu espacio.' },
  { pregunta: '¿Incluye flores y follaje el paquete de 10 metros?', respuesta: 'Sí, el paquete de 10 metros incluye flores (naturales o artificiales según tu preferencia) y follaje de eucalipto, ruscus o helecho intercalado entre los globos. Esto crea un estilo orgánico-botánico muy solicitado en bodas y eventos elegantes.' },
  { pregunta: '¿Cuánto tiempo tarda la instalación de 10 metros?', respuesta: 'La instalación de una guirnalda de 10 metros toma aproximadamente 2 a 2.5 horas. Nuestro equipo llega con la guirnalda pre-armada en secciones y la ensambla e instala directamente en tu venue. Cubrimos toda la CDMX y zona metropolitana.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '52',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La guirnalda orgánica de globos de 10 metros es nuestra opción premium para eventos de gran formato en la CDMX. Ideal para bodas elegantes, XV años, graduaciones y galas corporativas, esta guirnalda cubre arcos completos, escenarios, pistas de baile y recorridos de barandales en salones amplios con un diseño orgánico espectacular.</p>
      <p>Con colores ilimitados, acabados chrome, pastel y confeti, más flores y follaje integrados, esta guirnalda transforma cualquier venue en un espacio de ensueño. Nuestro equipo de decoradores profesionales se encarga de la instalación completa en mesas, escaleras, barandales y estructuras de todo tipo.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Guirnalda de 10 Metros: Diseño Orgánico Premium para Grandes Eventos</h2>
        <p>La guirnalda de globos de 10 metros es la pieza central de decoración para eventos que buscan un impacto visual extraordinario. En bodas, cubre arcos ceremoniales completos; en XV años, enmarca la pista de baile y el escenario; en graduaciones y eventos corporativos, transforma lobbies y salones principales en espacios memorables.</p>
        <p>Este paquete premium incluye un diseño orgánico con colores ilimitados y los acabados más exclusivos: globos chrome metálicos que reflejan la luz, globos de confeti que añaden textura visual, y globos pastel que aportan suavidad. Además, intercalamos flores naturales o artificiales y follaje de eucalipto, ruscus o helecho para un estilo botánico-orgánico que es tendencia absoluta en eventos de la CDMX.</p>
        <p>Nuestro equipo pre-arma la guirnalda en secciones modulares en nuestro taller y la transporta al venue para su ensamblaje final. La instalación toma entre 2 y 2.5 horas, y utilizamos sistemas profesionales de fijación que se adaptan a cualquier arquitectura: techos altos, columnas, barandales de hierro, paredes de cantera y estructuras metálicas en salones de Polanco, Interlomas, Santa Fe, Pedregal y toda la CDMX.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
