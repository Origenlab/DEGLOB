---
import Base from '../../../../layouts/Base.astro';
import Hero from '../../../../components/Hero.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import CtaBar from '../../../../components/CtaBar.astro';
import FaqSection from '../../../../components/FaqSection.astro';
import { SERVICIOS, WHATSAPP_URL_MSG, SITE_URL } from '../../../../lib/config';
import { faqSchema } from '../../../../lib/seo';

const servicio = SERVICIOS.find(s => s.slug === 'guirnaldas-de-globos')!;
const paquete = servicio.paquetes.find(p => p.slug === 'guirnalda-10-metros')!;
const otrosPaquetes = servicio.paquetes.filter(p => p.slug !== 'guirnalda-10-metros');

const faqItems = [
  { pregunta: '¿Qué se puede decorar con una guirnalda de 10 metros?', respuesta: 'Con 10 metros puedes decorar un pasillo completo, todo el contorno de una pista de baile, un barandal largo de escalera o crear un marco espectacular para un escenario o altar. Es ideal para espacios grandes.' },
  { pregunta: '¿Incluye flores y follaje?', respuesta: 'Sí, el paquete de 10 metros incluye flores artificiales y follaje natural o artificial integrado en la guirnalda. Esto crea una composición más rica que combina la textura de los globos con elementos botánicos.' },
  { pregunta: '¿Qué tipos de globos incluye?', respuesta: 'Incluye globos chrome (metálico espejo), pastel (mate suave), confeti (transparente con relleno) y latex estándar en colores ilimitados. La variedad de texturas crea una guirnalda con profundidad visual.' },
  { pregunta: '¿Se puede personalizar la forma de la guirnalda?', respuesta: 'Sí, podemos crear guirnaldas con forma de arco, ondulación, espiral ascendente o cualquier forma que se adapte a la arquitectura de tu espacio. La flexibilidad del diseño orgánico permite infinitas posibilidades.' },
  { pregunta: '¿Cuánto tiempo toma la instalación?', respuesta: 'La instalación de una guirnalda de 10 metros toma entre 2 y 3 horas con un equipo de 2 decoradores. Coordinamos el horario de acceso al venue para completar todo a tiempo.' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${paquete.nombre} — ${servicio.nombre}`,
    description: `Paquete ${paquete.nombre} de ${servicio.nombre.toLowerCase()}. ${servicio.descripcion}`,
    brand: { '@type': 'Organization', name: 'DEGLOB' },
    offers: {
      '@type': 'Offer',
      price: paquete.precio,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/servicios/${servicio.slug}/${paquete.slug}/`,
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '52',
      bestRating: '5',
    },
  },
  faqSchema(faqItems),
];
---

<Base
  title={`${paquete.nombre} — ${servicio.nombre} | DEGLOB`}
  description={`${paquete.nombre} de ${servicio.nombre.toLowerCase()} desde $${paquete.precio.toLocaleString()} MXN. ${paquete.features.slice(0, 3).join(', ')}. Instalación incluida en CDMX.`}
  structuredData={structuredData}
>
  <Breadcrumb items={[
    { name: 'Servicios', href: '/servicios/' },
    { name: servicio.nombre, href: `/servicios/${servicio.slug}/` },
    { name: paquete.nombre, href: `/servicios/${servicio.slug}/${paquete.slug}/` },
  ]} />

  <Hero
    badge={`${servicio.nombre} — ${paquete.nombre}`}
    title={`${paquete.nombre}`}
    description={`Paquete de ${servicio.nombre.toLowerCase()} que incluye ${paquete.features[0].toLowerCase()}. Instalación profesional incluida en toda la CDMX.`}
    primaryCta={{ text: `Cotizar $${paquete.precio.toLocaleString()} + IVA`, href: WHATSAPP_URL_MSG }}
    secondaryCta={{ text: 'Ver más paquetes', href: `/servicios/${servicio.slug}/` }}
  >
    <Fragment slot="hero-seo">
      <p>La guirnalda de globos de 10 metros es nuestra pieza decorativa de mayor impacto lineal. Con diseño orgánico premium, colores ilimitados, globos chrome, pastel y confeti más flores y follaje integrado, esta guirnalda transforma pasillos, pistas de baile y escenarios completos.</p>
      <p>Diez metros de decoración orgánica ofrecen una cobertura espectacular para los eventos más grandes de la CDMX. Cada metro se compone de docenas de globos en diferentes tamaños y acabados, creando una serpentina de color y textura que define visualmente cualquier espacio.</p>
    </Fragment>
  </Hero>

  <CtaBar
    items={otrosPaquetes.map(p => ({ label: p.nombre, href: `/servicios/${servicio.slug}/${p.slug}/` }))}
    headline="Otros paquetes disponibles"
  />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {paquete.features.map(f => (
          <div class="feature-item feature-item--yes">
            <span class="feature-item__icon">&#10003;</span>
            <span>{f}</span>
          </div>
        ))}
      </div>

      <div class="price-highlight">
        <span class="price-highlight__label">Precio desde</span>
        <span class="price-highlight__amount">${paquete.precio.toLocaleString()} <small>MXN + IVA</small></span>
        <span class="price-highlight__note">Instalación incluida en CDMX</span>
        <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener" style="margin-top:1rem">Reservar Ahora</a>
      </div>
    </div>
  </section>

  <section class="section section--bg">
    <div class="container">
      <div class="prose" style="max-width:800px">
        <h2>Guirnalda de 10 Metros: Decoración de Gran Formato</h2>
        <p>La guirnalda de globos de 10 metros es la declaración decorativa más impactante en formato lineal. Con esta longitud puedes transformar un pasillo completo en un camino de color, enmarcar toda una pista de baile con un perímetro de globos, o crear un marco monumental para un altar de ceremonia.</p>
        <p>La composición premium incluye globos chrome que brillan bajo cualquier iluminación, globos pastel que aportan suavidad, globos de confeti que agregan destellos, y flores y follaje que integran elementos naturales. Todo se distribuye orgánicamente en diferentes tamaños para lograr un efecto visual de alta complejidad.</p>
        <p>Este paquete es el elegido para bodas en haciendas con escalinatas amplias, XV años en salones de gran formato, y eventos corporativos donde se necesita cubrir distancias largas con decoración de primer nivel. La instalación requiere un equipo de 2 decoradores que trabajan durante 2-3 horas.</p>
      </div>
    </div>
  </section>

  <FaqSection items={faqItems} />

  <section class="cta-dark">
    <div class="container">
      <h2 class="cta-dark__title">¿Listo para reservar?</h2>
      <p class="cta-dark__text">Cotiza tu {paquete.nombre.toLowerCase()} y haz tu evento inolvidable.</p>
      <a href={WHATSAPP_URL_MSG} class="btn btn--accent" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .features-grid { display: grid; grid-template-columns: 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto var(--spacing-2xl); }
  .feature-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1rem; border-radius: var(--border-radius); font-size: var(--font-size-sm); }
  .feature-item--yes { background: #f0fdf4; color: #166534; }
  .feature-item__icon { font-weight: 700; flex-shrink: 0; }
  .price-highlight { text-align: center; padding: var(--spacing-xl); background: var(--color-bg); border-radius: var(--border-radius-lg); max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .price-highlight__label { font-size: var(--font-size-sm); color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
  .price-highlight__amount { font-size: 2.5rem; font-weight: 800; color: var(--color-primary); line-height: 1.2; }
  .price-highlight__amount small { font-size: 1rem; font-weight: 500; color: var(--color-text-light); }
  .price-highlight__note { font-size: var(--font-size-sm); color: var(--color-text-light); }
  @media (min-width: 640px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
