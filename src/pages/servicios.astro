---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import ContactForm from '../components/ContactForm.astro';

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Decoración con Globos",
  "provider": {
    "@type": "LocalBusiness",
    "name": "DEGLOB - Decoración con Globos CDMX",
    "telephone": "+52-1-56-3956-5117",
    "address": { "@type": "PostalAddress", "streetAddress": "Calz. Gral. Mariano Escobedo 555", "addressLocality": "Polanco, Miguel Hidalgo", "addressRegion": "CDMX", "postalCode": "11580", "addressCountry": "MX" }
  },
  "areaServed": { "@type": "City", "name": "Ciudad de México" }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://fantasyglobos.com.mx/" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://fantasyglobos.com.mx/servicios" }
  ]
});

const services = [
  { title: 'Arcos de Globos', badge: 'Más Popular', desc: 'Estructuras espectaculares que enmarcan cualquier espacio. Diseño orgánico o clásico según tu preferencia.', features: ['Arcos orgánicos asimétricos', 'Arcos clásicos simétricos', 'Integración con flores naturales', 'Tamaños desde 2m hasta 6m+'], img: '/img/servicios/arcos-de-globos.webp', imgAlt: 'Arcos de globos orgánicos y clásicos para eventos en CDMX' },
  { title: 'Columnas Decorativas', desc: 'Estructuras verticales elegantes que añaden altura y presencia a cualquier espacio de tu evento.', features: ['Efecto espiralado o recto', 'Alturas de 1.5m a 3m', 'Base estable incluida', 'Ideales para entradas'], img: '/img/servicios/columnas-globos.webp', imgAlt: 'Columnas decorativas de globos para entradas y escenarios' },
  { title: 'Backdrops y Paneles', desc: 'Muros completos de globos perfectos para photocalls, mesas principales y zonas de fotos.', features: ['Cobertura de pared completa', 'Diseños personalizados', 'Integración de letras/números', 'Efecto 3D disponible'], img: '/img/servicios/backdrop-globos.webp', imgAlt: 'Backdrop de globos para photocall y mesa principal' },
  { title: 'Globos con Helio', desc: 'Bouquets flotantes y arreglos con helio que añaden movimiento y magia a tu celebración.', features: ['Bouquets personalizados', 'Techos flotantes', 'Duración 24+ horas', 'Globos gigantes disponibles'], img: '/img/servicios/globos-helio.webp', imgAlt: 'Bouquets de globos con helio flotantes para fiestas' },
  { title: 'Figuras Personalizadas', desc: 'Creaciones únicas de globos que dan vida a personajes, números gigantes y formas especiales.', features: ['Números y letras gigantes', 'Personajes temáticos', 'Figuras de animales', 'Diseños a medida'], img: '/img/servicios/figuras-globos.webp', imgAlt: 'Figuras personalizadas de globos con números y personajes' },
  { title: 'Centros de Mesa', desc: 'Arreglos pequeños pero impactantes para las mesas de tus invitados. Combinamos globos con bases elegantes, flores y detalles temáticos que complementan perfectamente tu decoración.', features: ['Diseños coordinados', 'Con base decorativa', 'Opción con helio', 'Combinación con flores'], img: '/img/servicios/centros-mesa-globos.webp', imgAlt: 'Centros de mesa con globos elegantes para invitados' },
  { title: 'Guirnaldas de Globos', desc: 'Cadenas orgánicas de globos perfectas para decorar paredes, barandales, techos y espacios lineales. Versatilidad y elegancia que se adapta a cualquier ambiente y temática.', features: ['Decoración de paredes', 'Barandales y techos', 'Diseños orgánicos', 'Cualquier longitud'], img: '/img/servicios/guirnaldas-globos.webp', imgAlt: 'Guirnaldas orgánicas de globos para paredes y barandales' },
  { title: 'Globos Gigantes', desc: 'Globos de 3 pies o más que generan un impacto visual inmediato. Ideales para entradas, sesiones fotográficas, gender reveals y momentos especiales que requieren protagonismo.', features: ['Tamaños de 3 pies o más', 'Ideal para fotografías', 'Gender reveals', 'Impacto visual máximo'], img: '/img/servicios/globos-gigantes.webp', imgAlt: 'Globos gigantes de 3 pies para eventos y sesiones fotográficas' },
];

const steps = [
  { num: '1', title: 'Consulta', desc: 'Platícanos sobre tu evento, fecha, temática y presupuesto. Te asesoramos sin compromiso.' },
  { num: '2', title: 'Diseño', desc: 'Creamos una propuesta personalizada con colores, estilos y elementos que reflejen tu visión.' },
  { num: '3', title: 'Confirmación', desc: 'Aprobado el diseño, apartamos tu fecha con un anticipo y coordinamos los detalles del montaje.' },
  { num: '4', title: 'Montaje', desc: 'Llegamos puntual, instalamos todo y al finalizar tu evento, nos encargamos del desmontaje.' },
];
---
<Layout
  title="Servicios de Decoración con Globos en CDMX | Arcos, Columnas y Más | DEGLOB"
  description="Servicios profesionales de decoración con globos: arcos orgánicos, columnas decorativas, backdrops, globos con helio y figuras personalizadas. Cotiza sin compromiso en CDMX."
  schemas={[serviceSchema, breadcrumbSchema]}
>
  <Header />

  <HeroSection
    badge="Catálogo Completo de Servicios"
    title="Servicios de Decoración con Globos"
    titleAccent="Profesionales en CDMX"
    description="Descubre nuestra amplia gama de servicios de decoración con globos. Desde arcos orgánicos hasta instalaciones personalizadas, cada servicio incluye diseño, materiales premium y montaje profesional."
    ctaText="Ver Catálogo"
    ctaHref="#catalogo"
    seoTitle="Soluciones Creativas para Cada Tipo de Evento"
    seoText="En DEGLOB ofrecemos una variedad de servicios diseñados para cubrir todas las necesidades de decoración con globos. Ya sea que busques un arco orgánico espectacular, columnas elegantes para tu entrada, o un backdrop impresionante para las fotos, tenemos la solución perfecta."
    seoText2="Trabajamos con materiales de las mejores marcas como Qualatex, Sempertex y Anagram, garantizando durabilidad y acabados profesionales. Cada servicio incluye asesoría personalizada, diseño creativo adaptado a tu temática, montaje profesional en el lugar de tu evento y desmontaje al finalizar."
  />

  <!-- Proceso -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Cómo Trabajamos</span>
        <h2 class="section-title">Nuestro Proceso</h2>
        <p class="section-subtitle">Desde la consulta inicial hasta el montaje final, te acompañamos en cada paso</p>
      </div>
      <div class="grid-4">
        {steps.map(s => (
          <div class="step-card">
            <div class="step-num">{s.num}</div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Catálogo -->
  <section class="section" id="catalogo">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Catálogo de Servicios</span>
        <h2 class="section-title">Soluciones Creativas para tu Evento</h2>
        <p class="section-subtitle">Cada servicio incluye diseño personalizado, materiales premium y montaje profesional</p>
      </div>
      {services.map((s, i) => (
        <div class:list={['service-detail', { reverse: i % 2 !== 0 }]}>
          <div class="service-img">
            <img src={s.img} alt={s.imgAlt} loading="lazy" width="560" height="400" />
            {s.badge && <span class="service-badge">{s.badge}</span>}
          </div>
          <div class="service-info">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <ul class="service-features">
              {s.features.map(f => <li><i class="fas fa-check"></i> {f}</li>)}
            </ul>
            <a href="https://wa.me/5215639565117?text=Hola%2C%20me%20interesa%20el%20servicio%20de%20{encodeURIComponent(s.title)}" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer"><i class="fab fa-whatsapp"></i> Cotizar</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Cotizar -->
  <section class="section section-alt" id="cotizar">
    <div class="container">
      <ContactForm />
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container" style="text-align:center">
      <h2 class="section-title" style="color:#fff">¿Listo para Cotizar tu Decoración?</h2>
      <p style="color:#b2bec3;font-size:1.1rem;margin-bottom:32px">Cuéntanos sobre tu evento y recibe una propuesta personalizada sin compromiso en menos de 24 horas</p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
        <a href="https://wa.me/5215639565117?text=Hola%2C%20quiero%20cotizar%20decoraci%C3%B3n%20con%20globos" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer"><i class="fab fa-whatsapp"></i> WHATSAPP</a>
        <a href="/contacto" class="btn btn-outline">Enviar Mensaje</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
<style>
  .section-alt { background: #f8f9fa; }
  .cta-section { background: linear-gradient(135deg, #1a1a2e, #16213e); }
  .step-card {
    background: #fff;
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border: 1px solid #f0f0f0;
  }
  .step-num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8B30EE, #C900D4);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 auto 16px;
  }
  .step-card h3 { font-size: 1.1rem; margin-bottom: 10px; color: #1a1a2e; }
  .step-card p { font-size: 0.9rem; color: #636E72; line-height: 1.7; }
  .service-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    margin-bottom: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid #f0f0f0;
  }
  .service-detail:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .service-detail.reverse .service-img { order: 2; }
  .service-img { position: relative; border-radius: 16px; overflow: hidden; }
  .service-img img { width: 100%; height: auto; object-fit: cover; }
  .service-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: linear-gradient(135deg, #8B30EE, #C900D4);
    color: #fff;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
  }
  .service-info h3 { font-size: 1.5rem; margin-bottom: 16px; color: #1a1a2e; }
  .service-info p { color: #636E72; line-height: 1.7; margin-bottom: 20px; }
  .service-features { list-style: none; margin-bottom: 24px; }
  .service-features li {
    padding: 8px 0;
    color: #2d3436;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .service-features i { color: #00AB1A; font-size: 0.85rem; }
  @media (max-width: 768px) {
    .service-detail { grid-template-columns: 1fr; gap: 24px; }
    .service-detail.reverse .service-img { order: 0; }
  }
</style>
