---
interface Props {
  badge: string;
  title: string;
  titleAccent?: string;
  description: string;
  ctaWhatsapp?: boolean;
  ctaText?: string;
  ctaHref?: string;
  seoTitle?: string;
  seoText: string;
  seoText2?: string;
}

const {
  badge,
  title,
  titleAccent,
  description,
  ctaWhatsapp = true,
  ctaText,
  ctaHref,
  seoTitle,
  seoText,
  seoText2,
} = Astro.props;
---
<section class="hero">
  <div class="container hero-grid">
    <div class="hero-col1">
      <span class="section-badge">{badge}</span>
      <h1 class="hero-title">{title}{titleAccent && <><br/><span class="gradient-text">{titleAccent}</span></>}</h1>
      <p class="hero-desc">{description}</p>
      <div class="hero-ctas">
        {ctaWhatsapp && (
          <a href="https://wa.me/5215639565117?text=Hola%2C%20quiero%20cotizar%20decoraci%C3%B3n%20con%20globos" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">
            <i class="fab fa-whatsapp"></i> WHATSAPP
          </a>
        )}
        {ctaText && ctaHref && (
          <a href={ctaHref} class="btn btn-outline">{ctaText}</a>
        )}
      </div>
    </div>
    <div class="hero-col2">
      {seoTitle && <h2 class="seo-title">{seoTitle}</h2>}
      <p class="seo-text">{seoText}</p>
      {seoText2 && <p class="seo-text">{seoText2}</p>}
    </div>
  </div>
</section>
<style>
  .hero {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: #fff;
    padding: 80px 0;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-title {
    font-size: 2.8rem;
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .hero-desc {
    font-size: 1.1rem;
    color: #b2bec3;
    margin-bottom: 32px;
    line-height: 1.7;
  }
  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero-col2 {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 32px;
  }
  .seo-title {
    font-size: 1.4rem;
    margin-bottom: 16px;
    color: #a855f7;
  }
  .seo-text {
    font-size: 0.95rem;
    color: #b2bec3;
    line-height: 1.8;
    margin-bottom: 16px;
  }
  .seo-text:last-child { margin-bottom: 0; }
  @media (max-width: 992px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-title { font-size: 2.2rem; }
    .hero { padding: 60px 0; }
  }
  @media (max-width: 576px) {
    .hero-title { font-size: 1.8rem; }
    .hero { padding: 40px 0; }
    .hero-col2 { padding: 24px; }
  }
</style>
