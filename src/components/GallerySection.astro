---
const images = [
  { src: '/img/arcos-de-globos/arco-globos-boda-elegante-verde-durazno-follaje.webp', alt: 'Arco de globos elegante verde y durazno con follaje para boda' },
  { src: '/img/guirnaldas-de-globos/arco-globos-blanco-plateado-estrellas-sesion-fotos.webp', alt: 'Guirnalda de globos blanco y plateado con estrellas para sesión de fotos' },
  { src: '/img/columnas-decorativas/columnas-globos-apertura-azul-blanco-dorado-empresa.webp', alt: 'Columnas de globos azul blanco y dorado para apertura de empresa' },
  { src: '/img/globos-gigantes/globo-gigante-confeti-colores-fiesta-tassel-pista-baile.webp', alt: 'Globo gigante con confeti de colores y tassel en pista de baile' },
  { src: '/img/arcos-de-globos/arco-globos-baby-shower-rosa-durazno-its-a-girl.webp', alt: 'Arco de globos rosa y durazno para baby shower de niña' },
  { src: '/img/columnas-decorativas/columnas-globos-baby-shower-nina-rosa-biberon.webp', alt: 'Columnas de globos rosa con biberón para baby shower de niña' },
  { src: '/img/arcos-de-globos/arco-globos-blancos-flores-entrada-salon-lujo.webp', alt: 'Arco de globos blancos con flores en entrada de salón de lujo' },
  { src: '/img/globos-gigantes/globo-gigante-cobre-metalico-xv-anos-quinceañera-salon.webp', alt: 'Globo gigante cobre metálico para XV años en salón de quinceañera' },
  { src: '/img/guirnaldas-de-globos/arco-globos-boda-boho-terracota-pampas-macrame-atardecer.webp', alt: 'Arco de globos estilo boho terracota con pampas y macramé al atardecer' },
  { src: '/img/arcos-de-globos/arco-globos-blancos-plata-boda-elegante-salon.webp', alt: 'Arco de globos blancos y plata para boda elegante en salón' },
  { src: '/img/columnas-decorativas/columnas-globos-baby-shower-nino-azul-osito.webp', alt: 'Columnas de globos azules con osito para baby shower de niño' },
  { src: '/img/arcos-de-globos/arco-globos-boda-entrada-eucalipto-terracota.webp', alt: 'Arco de globos con eucalipto y terracota para entrada de boda' },
];
---
<section class="section gallery-section">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Galería</span>
      <h2 class="section-title">Nuestros Trabajos de Decoración con Globos</h2>
      <p class="section-subtitle">Inspírate con algunos de nuestros eventos más recientes</p>
    </div>
    <div class="gallery-grid">
      {images.map(img => (
        <div class="gallery-item">
          <img src={img.src} alt={img.alt} loading="lazy" width="400" height="300" />
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .gallery-section { background: #f8f9fa; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .gallery-item {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4/3;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (max-width: 992px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 576px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
