---
const currentPath = Astro.url.pathname;
---
<header>
  <nav class="navbar">
    <div class="container nav-inner">
      <a href="/" class="nav-logo" aria-label="DEGLOB - Inicio">
        <img src="/img/decoracion-con-globos.avif" alt="DEGLOB — Decoración con Globos CDMX" class="nav-logo__img" width="180" height="60" loading="eager" decoding="async" fetchpriority="high" />
      </a>
      <button class="nav-toggle" aria-label="Abrir menú" id="navToggle">
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
      </button>
      <ul class="nav-menu" id="navMenu">
        <li><a href="/" class:list={[{ active: currentPath === '/' }]}>Inicio</a></li>
        <li><a href="/servicios" class:list={[{ active: currentPath === '/servicios' || currentPath === '/servicios/' }]}>Servicios</a></li>
        <li><a href="/nosotros" class:list={[{ active: currentPath === '/nosotros' || currentPath === '/nosotros/' }]}>Nosotros</a></li>
        <li><a href="/contacto" class:list={[{ active: currentPath === '/contacto' || currentPath === '/contacto/' }]}>Contacto</a></li>
        <li><a href="https://wa.me/5215639565117?text=Hola%2C%20quiero%20cotizar%20decoraci%C3%B3n%20con%20globos" class="nav-cta" target="_blank" rel="noopener noreferrer">Cotizar</a></li>
      </ul>
    </div>
  </nav>
</header>
<script is:inline>
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('navMenu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
</script>
<style>
  /* Navbar */
  .navbar {
    background: #8f2fef;
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 64px;
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .nav-logo__img {
    height: 72px;
    width: auto;
    max-width: 270px;
    object-fit: contain;
    display: block;
  }

  /* Nav Links */
  .nav-menu {
    display: flex;
    list-style: none;
    gap: 4px;
    align-items: center;
    margin: 0;
    padding: 0;
  }
  .nav-menu a {
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.95rem;
    color: #fff;
    text-decoration: none;
  }
  .nav-menu a:hover,
  .nav-menu a.active {
    color: #fff;
    background: rgba(255,255,255,0.15);
  }
  .nav-cta {
    background: #fff !important;
    color: #8f2fef !important;
    border-radius: 50px !important;
    padding: 10px 24px !important;
    font-weight: 700 !important;
    transition: opacity 0.2s;
  }
  .nav-cta:hover { opacity: 0.9; }

  /* Hamburger */
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    flex-direction: column;
    gap: 5px;
  }
  .nav-toggle__line {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .header-contact span:last-child { display: none; }
    .nav-toggle { display: flex; }
    .nav-menu {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #8f2fef;
      padding: 16px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      z-index: 99;
    }
    .nav-menu.open { display: flex; }
    .nav-menu a { padding: 12px 16px; }
    .nav-cta { text-align: center; width: 100%; display: block !important; }
  }
  @media (max-width: 480px) {
    .header-top { display: none; }
  }
</style>
